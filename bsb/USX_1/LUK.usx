  <para style="q1">
    <verse number="26" style="v" sid="LUK 6:26" /><char style="wj"><char style="w" strong="G03759">Woe to you</char> <char style="w" strong="G03752">when</char> <char style="w" strong="G03956">all</char> <char style="w" strong="G00444">men</char> <char style="w" strong="G02036">speak</char> <char style="w" strong="G02573">well</char> <char style="w" strong="G04771">of you</char>,</char></para>
