  <para style="q1">
    <verse number="48" style="v" sid="LUK 1:48" /><char style="w" strong="G03754">For</char> <char style="w" strong="G01914">He has looked with favor</char> <char style="w" strong="G01909">on</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G05014">humble state</char> <char style="w" strong="G03588">of</char> <char style="w" strong="G00846">His</char> <char style="w" strong="G01399">servant</char>.</para>
  <para style="q2" vid="LUK 1:48"><char style="w" strong="G00575">From</char> <char style="w" strong="G03568">now on</char> <char style="w" strong="G03956">all</char> <char style="w" strong="G01074">generations</char> <char style="w" strong="G03106">will call me blessed</char>.<verse eid="LUK 1:48" /></para>
  <para style="q1">
