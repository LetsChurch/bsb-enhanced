  <para style="s1">The Beatitudes</para>
  <para style="p">
    <verse number="20" style="v" sid="LUK 6:20" /><char style="w" strong="G01869">Looking up</char> <char style="w" strong="G01519">at</char> <char style="w" strong="G00846">His</char> <char style="w" strong="G03101">disciples</char>, <char style="w" strong="G00846">Jesus</char> <char style="w" strong="G02036">said</char>:</para>
  <para style="q1" vid="LUK 6:20"><char style="wj">“<char style="w" strong="G03107">Blessed are</char> <char style="w" strong="G03588">you who are</char> <char style="w" strong="G04434">poor</char>,</char></para>
  <para style="q2" vid="LUK 6:20"><char style="wj"><char style="w" strong="G03754">for</char> <char style="w" strong="G05212">yours</char> <char style="w" strong="G01510">is</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G00932">kingdom</char> <char style="w" strong="G02316">of God</char>.</char><verse eid="LUK 6:20" /></para>
  <para style="q1">
    <verse number="21" style="v" sid="LUK 6:21" /><char style="wj"><char style="w" strong="G03107">Blessed are</char> <char style="w" strong="G03588">you who</char> <char style="w" strong="G03983">hunger</char> <char style="w" strong="G03568">now</char>,</char></para>
  <para style="q2" vid="LUK 6:21"><char style="wj"><char style="w" strong="G03754">for</char> <char style="w" strong="G05526">you will be filled</char>.</char></para>
