  <para style="q2" vid="LUK 6:21"><char style="wj"><char style="w" strong="G03754">for</char> <char style="w" strong="G01070">you will laugh</char>.</char><verse eid="LUK 6:21" /></para>
  <para style="p">
    <verse number="22" style="v" sid="LUK 6:22" /><char style="wj"><char style="w" strong="G03107">Blessed</char> <char style="w" strong="G01510">are you</char> <char style="w" strong="G03752">when</char> <char style="w" strong="G00444">people</char> <char style="w" strong="G03404">hate</char> <char style="w" strong="G04771">you</char>, <char style="w" strong="G02532">and</char> <char style="w" strong="G03752">when</char> <char style="w" strong="G00873">they exclude you</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G03679">insult</char> <char style="w" strong="G04771">you</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G01544">reject</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G03686">name</char> <char style="w" strong="G05613">as</char> <char style="w" strong="G04190">evil</char> <char style="w" strong="G01752">because of</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G05207">Son</char> <char style="w" strong="G00444">of Man</char>.</char> <verse eid="LUK 6:22" /><verse number="23" style="v" sid="LUK 6:23" /><char style="wj"><char style="w" strong="G05463">Rejoice</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G01565">that</char> <char style="w" strong="G02250">day</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G04640">leap for joy</char>, <char style="w" strong="G01063">because</char> <char style="w" strong="G04183">great is</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G03408">reward</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G03772">heaven</char>. <char style="w" strong="G01063">For</char> <char style="w" strong="G00846">their</char> <char style="w" strong="G03962">fathers</char> <char style="w" strong="G04160">treated</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G04396">prophets</char> <char style="w" strong="G00846">in the same way</char>.</char><verse eid="LUK 6:23" /></para>
  <para style="s1">Woes to the Satisfied</para>
