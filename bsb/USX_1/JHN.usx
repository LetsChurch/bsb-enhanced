  <para style="p" vid="JHN 20:16"><char style="w" strong="G01565">She</char> <char style="w" strong="G04762">turned</char> <char style="w" strong="G03004">and said</char> <char style="w" strong="G00846">to Him</char> <char style="w" strong="G01447">in Hebrew</char>,<note caller="+" style="f"><char style="fr" closed="false">20:16 </char><char style="ft" closed="false">Or </char><char style="fqa" closed="false">in Aramaic</char></note> “<char style="w" strong="G04462">Rabboni</char>!” ( <char style="w" strong="G03739">which</char> <char style="w" strong="G03004">means</char> “<char style="w" strong="G01320">Teacher</char>” ).<verse eid="JHN 20:16" /></para>
  <para style="p">
