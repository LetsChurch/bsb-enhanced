the</char> <char style="w" strong="G03962">Father</char> <char style="w" strong="G01510">is</char> <char style="w" strong="G03173">greater than</char> <char style="w" strong="G01473">I</char>.</char> <verse eid="JHN 14:28" /><verse number="29" style="v" sid="JHN 14:29" /><char style="wj"><char style="w" strong="G02532">And</char> <char style="w" strong="G03568">now</char> <char style="w" strong="G02046">I have told</char> <char style="w" strong="G04771">you</char> <char style="w" strong="G04250">before</char> <char style="w" strong="G01096">it happens</char>, <char style="w" strong="G02443">so that</char> <char style="w" strong="G03752">when</char> <char style="w" strong="G01096">it does happen</char>, <char style="w" strong="G04100">you will believe</char>.</char><verse eid="JHN 14:29" /></para>
  <para style="p">
