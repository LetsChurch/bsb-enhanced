  <para style="s1">Jesus Promises the Holy Spirit</para>
  <para style="p">
    <verse number="15" style="v" sid="JHN 14:15" /><char style="wj"><char style="w" strong="G01437">If</char> <char style="w" strong="G00025">you love</char> <char style="w" strong="G01473">Me</char>, <char style="w" strong="G05083">you will keep</char><note caller="+" style="f"><char style="fr" closed="false">14:15 </char><char style="ft" closed="false">Or </char><char style="fqa" closed="false">If you love Me, keep</char></note> <char style="w" strong="G01699">My</char> <char style="w" strong="G01785">commandments</char>.</char> <verse eid="JHN 14:15" /><verse number="16" style="v" sid="JHN 14:16" /><char style="wj"><char style="w" strong="G02504">And I</char> <char style="w" strong="G02065">will ask</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G03962">Father</char>, <char style="w" strong="G02532">and</char> <char style="w" strong="G01325">He will give</char> <char style="w" strong="G04771">you</char> <char style="w" strong="G00243">another</char> <char style="w" strong="G03875">Advocate</char><note caller="+" style="f"><char style="fr" closed="false">14:16 </char><char style="ft" closed="false">Or </char><char style="fqa" closed="false">Comforter </char><char style="ft" closed="false">or </char><char style="fqa" closed="false">Helper </char><char style="ft" closed="false">or </char><char style="fqa" closed="false">Counselor</char><char style="ft" closed="false">; Greek </char><char style="fqa" closed="false">Paraclete</char><char style="ft" closed="false">; also in verse 26</char></note> <char style="w" strong="G02443">to</char> <char style="w" strong="G01510">be</char> <char style="w" strong="G03326">with</char> <char style="w" strong="G04771">you</char> <char style="w" strong="G00165">forever</char></char> — <verse eid="JHN 14:16" /><verse number="17" style="v" sid="JHN 14:17" /><char style="wj"><char style="w" strong="G03588">the</char> <char style="w" strong="G04151">Spirit</char> <char style="w" strong="G00225">of truth</char>. 