="G04771">to you</char>, <char style="w" strong="G02980">I do not speak</char> <char style="w" strong="G00575">on</char> <char style="w" strong="G01683">My own</char>. <char style="w" strong="G01161">Instead</char>, <char style="w" strong="G03588">it is the</char> <char style="w" strong="G03962">Father</char> <char style="w" strong="G03306">dwelling</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G01473">Me</char>, <char style="w" strong="G04160">performing</char> <char style="w" strong="G00846">His</char> <char style="w" strong="G02041">works</char>.</char> <verse eid="JHN 14:10" /><verse number="11" style="v" sid="JHN 14:11" /><char style="wj"><char style="w" strong="G04100">Believe</char> <char style="w" strong="G01473">Me</char> <char style="w" strong="G03754">that</char> <char style="w" strong="G01473">I am</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G03962">Father</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G03962">Father</char> <char style="w" strong="G01722">is in</char> <char style="w" strong="G01473">Me</char> — <char style="w" strong="G01161">or at least</char> <char style="w" strong="G04100">believe</char> <char style="w" strong="G01223">on account of</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G02041">works</char> <char style="w" strong="G00846">themselves</char>.</char><verse eid="JHN 14:11" /></para>
  <para style="p">
    <verse number="12" style="v" sid="JHN 14:12" /><char style="wj"><char style="w" strong="G00281">Truly</char>, <char style="w" strong="G00281">truly</char>, <char style="w" strong="G03004">I tell</char> <char style="w" strong="G04771">you</char>, <char style="w" strong="G03588">whoever</char> <char style="w" strong="G04100">believes</char> <char style="w" strong="G01519">in</char> <char style="w" strong="G01473">Me</char> <char style="w" strong="G04160">will also do</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G02041">works</char> <char style="w" strong="G03739">that</char> <char style="w" strong="G01473">I</char> <char style="w" strong="G04160">am doing</char>. <char style="w" strong="G04160">He will do</char> <char style="w" strong="G02532">even</char> <char style="w" strong="G03173">greater things</char> <char style="w" strong="G03778">than these</char>, <char style="w" strong="G03754">because</char> <char style="w" strong="G01473">I</char> <char style="w" strong="G04198">am going</char> <char style="w" strong="G04314">to</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G03962">Father</char>.</char> <verse eid="JHN 14:12" /><verse number="13" style="v" sid="JHN 14:13" /><char style="wj"><char style="w" strong="G02532">And</char> <char style="w" strong="G04160">I will do</char> <char style="w" strong="G03754">whatever</char> <char style="w" strong="G00154">you ask</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G01473">My</char> <char style="w" strong="G03686">name</char>, <char style="w" strong="G02443">so that</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G03962">Father</char> <char style="w" strong="G01392">may be glorified</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G05207">Son</char>.</char> <verse eid="JHN 14:13" /><verse number="14" style="v" sid="JHN 14:14" /><char style="wj"><