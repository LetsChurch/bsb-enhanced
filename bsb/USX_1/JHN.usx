  <para style="s1">In My Father’s House Are Many Rooms</para>
  <para style="p">
    <verse number="1" style="v" sid="JHN 14:1" /><char style="wj">“<char style="w" strong="G03361">Do not let</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G02588">hearts</char> <char style="w" strong="G05015">be troubled</char>. <char style="w" strong="G04100">You believe</char> <char style="w" strong="G01519">in</char> <char style="w" strong="G02316">God</char>;<note caller="+" style="f"><char style="fr" closed="false">14:1 </char><char style="ft" closed="false">Or </char><char style="fqa" closed="false">Believe in God</char></note> <char style="w" strong="G04100">believe</char> <char style="w" strong="G01519">in</char> <char style="w" strong="G01473">Me</char> <char style="w" strong="G02532">as well</char>.</char> <verse eid="JHN 14:1" /><verse number="2" style="v" sid="JHN 14:2" /><char style="wj"><char style="w" strong="G01722">In</char> <char style="w" strong="G01473">My</char> <char style="w" strong="G03962">Father’s</char> <char style="w" strong="G03614">house</char> <char style="w" strong="G01510">are</char> <char style="w" strong="G04183">many</char> <char style="w" strong="G03438">rooms</char>. <char style="w" strong="G01487">If</char> <char style="w" strong="G03361">it were not</char> <char style="w" strong="G00302">so</char>, <char style="w" strong="G02036">would I have told</char> <char style="w" strong="G04771">you</char> <char style="w" strong="G03754">that</char> <char style="w" strong="G04198">I am going there</char> <char style="w" strong="G02090">to prepare</char> <char style="w" strong="G05117">a place</char> <char style="w" strong="G04771">for you</char>?</char><note caller="+" style="f"><char style="fr" closed="false">14:2 </char><char style="ft" closed="false">Or </char><char style="fqa" closed="false">If it were not so, I would have told you. I am going there to prepare a place for you.</char></note> <verse eid="JHN 14:2" /><verse number="3" style="v" sid="JHN 14:3" /><char style="wj"><char style="w" strong="G02532">And</char> <char style="w" strong="G01437">if</char> <char style="w" strong="G04198">I go</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G02090">prepare</char> <char style="w" strong="G05117">a place</char> <char style="w" strong="G04771">for you</char>, <char style="w" strong="G02064">I will come</char> <char style="w" strong="G03825">back</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G03880">welcome</char> <char style="w" strong="G04771">you</char> <char style="w" strong="G04314">into</char> <char style="w" strong="G01683">My presence</char>, <char style="w" strong="G02443">so that</char> <char style="w" strong="G04771">you</char> <char style="w" strong="G02532">also</char> <char style="w" strong="G01510">may be</char> <char style="w" strong="G03699">where</char> <char style="w" strong="G01473">I</char> <char style="w" strong="G01510">am</char>.</char> <verse eid="JHN 14:3" /><verse number="4" style="v" sid="JHN 14:4" /><char style="wj"><char style="w" strong="G01492">You know</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G03598">way</char> <char style="w" strong="G03699">to the place where</char> <char style="w" strong="G01473">I</char> <char style="w" strong="G05217">am going</char>.</char><note caller="+" style="f"><char style="fr" closed="false">14:4 </char><char style="ft" closed="false">BYZ and TR </char><char style="fqa" closed="false">And where I go you know, and the way you know.</char></note>”<verse eid="JHN 14:4" /></para>
  <para style="s1">The Way, the Truth, and the Life</para>
  <para style="p">
    <verse number="5" style="v" sid="JHN 14:5" />“<char style="w" strong="G02962">Lord</char>,” <char style="w" strong="G03004">said</char> <char style="w" strong="G02381">Thomas</char>, “<char style="w" strong="G01492">we do not know</char> <char style="w" strong="G04226">where</char> <char style="w" strong="G05217">You are going</char>, <char style="w" strong="G04459">so how</char> <char style="w" strong="G01410">can we</char> <char style="w" strong="G01492">know</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G03598">way</char>?”<verse eid="JHN 14:5" /></para>
