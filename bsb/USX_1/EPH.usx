  <para style="p">
    <verse number="25" style="v" sid="EPH 4:25" /><char style="w" strong="G01352">Therefore</char> <char style="qt"><char style="w" strong="G01538">each of you</char> <char style="w" strong="G00659">must put off</char> <char style="w" strong="G05579">falsehood</char> <char style="w" strong="G02980">and speak</char> <char style="w" strong="G00225">truthfully</char> <char style="w" strong="G03326">to</char> <char style="w" strong="G00846">his</char> <char style="w" strong="G04139">neighbor</char></char><note caller="+" style="x"><char style="xt" closed="false">Zech 8:16</char></note>, <char style="w" strong="G03754">for</char> <char style="w" strong="G01510">we are all</char> <char style="w" strong="G03196">members</char> <char style="w" strong="G00240">of one another</char>. <verse eid="EPH 4:25" /><verse number="26" style="v" sid="EPH 4:26" />“<char style="qt"><char style="w" strong="G03710">Be angry</char>, <char style="w" strong="G02532">yet</char> <char style="w" strong="G03361">do not</char> <char style="w" strong="G00264">sin</char></char><note caller="+" style="x"><char style="xt" closed="false">Ps 4:4</char></note>.”<note caller="+" style="f"><char style="fr" closed="false">4:26 </char><char style="ft" closed="false">Or </char><char style="fqa" closed="false">“In your anger do not sin.”</char><char style="ft" closed="false">Psalm 4:4</char></note> <char style="w" strong="G03361">Do not let</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G02246">sun</char> <char style="w" strong="G01931">set</char> <char style="w" strong="G01909">upon</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G03950">anger</char>, <verse eid="EPH 4:26" /><verse number="27" style="v" sid="EPH 4:27" /><char style="w" strong="G03366">and do not</char> <char style="w" strong="G01325">give</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G01228">devil</char> <char style="w" strong="G05117">a foothold</char>.<verse eid="EPH 4:27" /></para>
  <para style="p">
    <verse number="28" style="v" sid="EPH 4:28" /><char style="w" strong="G03588">He who</char> <char style="w" strong="G02813">has been stealing</char> <char style="w" strong="G02813">must steal</char> <char style="w" strong="G03371">no longer</char>, <char style="w" strong="G01161">but</char> <char style="w" strong="G02872">must work</char>, <char style="w" strong="G02038">doing</char> <char style="w" strong="G00018">good</char> <char style="w" strong="G03588">with</char> <char style="w" strong="G02398">his own</char> <char style="w" strong="G05495">hands</char>, <char style="w" strong="G02443">that</char> <char style="w" strong="G02192">he may have something</char> <char style="w" strong="G03330">to share with</char> <char style="w" strong="G03588">the one</char> <char style="w" strong="G02192">in</char> <char style="w" strong="G05532">need</char>.<verse eid="EPH 4:28" /></para>
  <para style="p">
    <verse number="29" style="v" sid="EPH 4:29" /><char style="w" strong="G03361">Let no</char> <char style="w" strong="G04550">unwholesome</char> <char style="w" strong="G03056">talk</char> <char style="w" strong="G01607">come</char> <char style="w" strong="G01537">out of</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G04750">mouths</char>, <char style="w" strong="G00235">but</char> <char style="w" strong="G01487">only</char> <char style="w" strong="G05100">what is</char> <char style="w" strong="G00018">helpful</char> <char style="w" strong="G04314">for</char> <char style="w" strong="G03619">building up</char> <char style="w" strong="G03588">the one</char> <char style="w" strong="G05532">in need</char> <char style="w" strong="G02443">and</char> <char style="w" strong="G01325">bringing</char> <char style="w" strong="G05485">grace</char> <char style="w" strong="G03588">to those</char> <char style="w" strong="G00191">who listen</char>.<verse eid="EPH 4:29" /></para>
  <para style="p">
    <verse number="30" style="v" sid="EPH 4:30" /><char style="w" strong="G02532">And</char> <char style="w" strong="G03361">do not</char> <char style="w" strong="G03076">grieve</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G00040">Holy</char> <char style="w" strong="G04151">Spirit</char> <char style="w" strong="G02316">of God</char>, <char style="w" strong="G01722">in</char> <char style="w" strong="G03739">whom</char> <char style="w" strong="G04972">you were sealed</char> <char style="w" strong="G01519">for</char> <char style="w" strong="G02250">the day</char> <char style="w" strong="G00629">of redemption</char>.<verse eid="EPH 4:30" /></para>
  <para style="p">
    <verse number="31" style="v" sid="EPH 4:31" /><char style="w" strong="G00142">Get rid of</char> <char style="w" strong="G03956">all</char> <char style="w" strong="G04088">bitterness</char>, <char style="w" strong="G02372">rage</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G03709">anger</char>, <char style="w" strong="G02906">outcry</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G00988">slander</char>, <char style="w" strong="G04862">along with</char> <char style="w" strong="G03956">every form</char> <char style="w" strong="G02549">of malice</char>. <verse eid="EPH 4:31" /><verse number="32" style="v" sid="EPH 4:32" /><char style="w" strong="G01096">Be</char> <char style="w" strong="G05543">kind</char> <char style="w" strong="G02155">and tenderhearted</char> <char style="w" strong="G01519">to</char> <char style="w" strong="G00240">one another</char>, <char style="w" strong="G05483">forgiving</char> <char style="w" strong="G01438">each other</char> <char style="w" strong="G02532">just</char> <char style="w" strong="G02531">as</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G05547">Christ</char> <char style="w" strong="G02316">God</char> <char style="w" strong="G05483">forgave</char> <char style="w" strong="G04771">you</char>.<verse eid="EPH 4:32" /></para>
  <chapter eid="EPH 4" />
