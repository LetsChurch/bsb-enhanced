  <para style="p">
    <verse number="29" style="v" sid="1CO 14:29" /><char style="w" strong="G01417">Two</char> <char style="w" strong="G02228">or</char> <char style="w" strong="G05140">three</char> <char style="w" strong="G04396">prophets</char> <char style="w" strong="G02980">should speak</char>, <char style="w" strong="G02532">and</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G00243">others</char> <char style="w" strong="G01252">should weigh carefully what is said</char>. <verse eid="1CO 14:29" /><verse number="30" style="v" sid="1CO 14:30" /><char style="w" strong="G01161">And</char> <char style="w" strong="G01437">if</char> <char style="w" strong="G00601">a revelation comes</char> <char style="w" strong="G00243">to someone who</char> <char style="w" strong="G02521">is seated</char>, <char style="w" strong="G03588">the</char> <char style="w" strong="G04413">first speaker</char> <char style="w" strong="G04601">should stop</char>. <verse eid="1CO 14:30" /><verse number="31" style="v" sid="1CO 14:31" /><char style="w" strong="G01063">For</char> <char style="w" strong="G01410">you can</char> <char style="w" strong="G03956">all</char> <char style="w" strong="G04395">prophesy</char> <char style="w" strong="G02596">in</char> <char style="w" strong="G01520">turn</char> <char style="w" strong="G02443">so that</char> <char style="w" strong="G03956">everyone</char> <char style="w" strong="G03129">may be instructed</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G03870">encouraged</char>. <verse eid="1CO 14:31" /><verse number="32" style="v" sid="1CO 14:32" /><char style="w" strong="G04151">The spirits</char> <char style="w" strong="G04396">of prophets</char> <char style="w" strong="G05293">are subject</char> <char style="w" strong="G04396">to prophets</char>. <verse eid="1CO 14:32" /><verse number="33" style="v" sid="1CO 14:33" /><char style="w" strong="G01063">For</char> <char style="w" strong="G01510">God is</char> <char style="w" stro