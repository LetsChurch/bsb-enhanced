  <para style="p">
    <verse number="12" style="v" sid="1CO 3:12" /><char style="w" strong="G01487">If</char> <char style="w" strong="G05100">anyone</char> <char style="w" strong="G02026">builds</char> <char style="w" strong="G01909">on</char> <char style="w" strong="G03588">this</char> <char style="w" strong="G02310">foundation</char> <char style="w" strong="G05557">using gold</char>, <char style="w" strong="G00696">silver</char>, <char style="w" strong="G05093">precious</char> <char style="w" strong="G03037">stones</char>, <char style="w" strong="G03586">wood</char>, <char style="w" strong="G05528">hay</char>, <char style="w" strong="G02562">or straw</char>, <verse eid="1CO 3:12" /><verse number="13" style="v" sid="1CO 3:13" /><char style="w" strong="G01538">his</char> <char style="w" strong="G02041">workmanship</char> <char style="w" strong="G01096">will be</char> <char style="w" strong="G05318">evident</char>, <char style="w" strong="G01063">because</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G02250">Day</char> <char style="w" strong="G01213">will bring it to light</char>. <char style="w" strong="G00601">It will be revealed</char> <char style="w" strong="G01722">with</char> <char style="w" strong="G04442">fire</char>, <char style="w" strong="G02532">and</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G04442">fire</char> <char style="w" strong="G01381">will prove</char> <char style="w" strong="G03697">the quality</char> <char style="w" strong="G01538">of each</char> <char style="w" strong="G03588">man’s</char> <char style="w" strong="G02041">work</char>. <verse eid="1CO 3:13" /><verse number="14" style="v" sid="1CO 3:14" /><char style="w" strong="G01487">If</char> <char style="w" strong="G02026">what he has built</char> <char style="w" strong="G03306">survives</char>, <char style="w" strong="G02983">he will receive</char> <char style="w" strong="G03408">a reward</char>. <verse eid="1CO 3:14" /><verse number="15" style="v" sid