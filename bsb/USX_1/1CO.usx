  <para style="p">
    <verse number="22" style="v" sid="1CO 14:22" /><char style="w" strong="G01100">Tongues</char>, <char style="w" strong="G05620">then</char>, <char style="w" strong="G01510">are</char> <char style="w" strong="G04592">a sign</char>, <char style="w" strong="G03756">not</char> <char style="w" strong="G03588">for</char> <char style="w" strong="G04100">believers</char>, <char style="w" strong="G00235">but</char> <char style="w" strong="G03588">for</char> <char style="w" strong="G00571">unbelievers</char>. <char style="w" strong="G04394">Prophecy</char>, <char style="w" strong="G00235">however</char>, <char style="w" strong="G03588">is for</char> <char style="w" strong="G04100">believers</char>, <char style="w" strong="G03756">not</char> <char style="w" strong="G03588">for</char> <char style="w" strong="G00571">unbelievers</char>.<verse eid="1CO 14:22" /></para>
  <para style="p">
