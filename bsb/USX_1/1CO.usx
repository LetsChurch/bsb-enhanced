  <para style="p">
    <verse number="15" style="v" sid="1CO 14:15" /><char style="w" strong="G05101">What</char> <char style="w" strong="G03767">then</char> <char style="w" strong="G01510">shall I do</char>? <char style="w" strong="G04336">I will pray</char> <char style="w" strong="G03588">with my</char> <char style="w" strong="G04151">spirit</char>, <char style="w" strong="G01161">but</char> <char style="w" strong="G04336">I will also pray</char> <char style="w" strong="G03588">with my</char> <char style="w" strong="G03563">mind</char>. <char style="w" strong="G05567">I will sing</char> <char style="w" strong="G03588">with my</char> <char style="w" strong="G04151">spirit</char>, <char style="w" strong="G01161">but</char> <char style="w" strong="G05567">I will also sing</char> <char style="w" strong="G03588">with my</char> <char style="w" strong="G03563">mind</char>. <verse eid="1CO 14:15" /><verse number="16" style="v" sid="1CO 14:16" /><char style="w" strong="G01893">Otherwise</char>, <char style="w" strong="G01437">if</char> <char style="w" strong="G02127">you speak a blessing</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G04151">spirit</char>,<note caller="+" style="f"><char style="fr" closed="false">14:16 </char><char style="ft" closed="false">Or </char><char style="fqa" closed="false">in the Spirit</char></note> <char style="w" strong="G04459">how</char> <char style="w" strong="G03588">can someone</char> <char style="w" strong="G02399">who is uninstructed</char> <char style="w" strong="G02046">say</char> “<char style="w" strong="G00281">Amen</char>” <char style="w" strong="G01909">to</char> <char style="w" strong="G04674">your</char> <char style="w" strong="G02169">thanksgiving</char>, <char style="w" strong="G01894">since</char> <char style="w" strong="G01492">he does not know</char> <char style="w" strong="G05101">what</char> <char style="w" strong="G03004">you are saying</char>? <verse eid="1CO 14:16" /><verse number="17" style="v" sid="1CO 14:17" 