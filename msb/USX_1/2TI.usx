  <para style="p">
    <verse number="5" style="v" sid="2TI 1:5" /><char style="w" strong="G05280">I am reminded</char> <char style="w" strong="G03588">of</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G00505">sincere</char> <char style="w" strong="G04102">faith</char>, <char style="w" strong="G03748">which</char> <char style="w" strong="G04412">first</char> <char style="w" strong="G01774">dwelt</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G03125">grandmother</char> <char style="w" strong="G03090">Lois</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G03384">mother</char> <char style="w" strong="G02131">Eunice</char>, <char style="w" strong="G01161">and</char> <char style="w" strong="G03982">I am convinced</char> <char style="w" strong="G01722">is in</char> <char style="w" strong="G04771">you</char> <char style="w" strong="G02532">as well</char>.<verse eid="2TI 1:5" /></para>
  <para style="p">
