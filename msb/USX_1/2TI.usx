  <para style="p">
    <verse number="15" style="v" sid="2TI 1:15" /><char style="w" strong="G01492">You know</char> <char style="w" strong="G03754">that</char> <char style="w" strong="G03956">everyone</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G00773">the Province of Asia</char><note caller="+" style="f"><char style="fr" closed="false">1:15 </char><char style="ft" closed="false">Literally </char><char style="fqa" closed="false">in Asia</char><char style="ft" closed="false">; Asia was a Roman province in what is now western Turkey. </char></note> <char style="w" strong="G00654">has deserted</char> <char style="w" strong="G01473">me</char>, <char style="w" strong="G03739">including</char> <char style="w" strong="G05436">Phygelus</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G02061">Hermogenes</char>.<verse eid="2TI 1:15" /></para>
  <para style="p">
    <verse number="16" style="v" sid="2TI 1:16" /><char style="w" strong="G03588">May the</char> <char style="w" strong="G02962">Lord</char> <char style="w" strong="G01325">grant</char> <char style="w" strong="G01656">mercy</char> <char style="w" strong="G03588">to the</char> <char style="w" strong="G03624">household</char> <char style="w" strong="G03683">of Onesiphorus</char>, <char style="w" strong="G03754">because</char> <char style="w" strong="G00404">he has often refreshed</char> <char style="w" strong="G01473">me</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G01870">was unashamed of</char> <char style="w" strong="G01473">my</char> <char style="w" strong="G00254">chains</char>. <verse eid="2TI 1:16" /><verse number="17" style="v" sid="2TI 1:17" /><char style="w" strong="G00235">Indeed</char>, <char style="w" strong="G01096">when he arrived</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G04516">Rome</char>, <char style="w" strong="G02212">he searched very diligently</char><note caller="+" style="f"><char style="fr" closed="false">1:17 </char><char style="ft" closed="false">CT </char><char style="fqa" closed="false">he searched diligently</char></note> <char style="w" strong="G02532">until</char> <char style="w" strong="G02147">he found</char> <char style="w" strong="G01473">me</char>.<verse eid="2TI 1:17" /></para>
  <para style="p">
    <verse number="18" style="v" sid="2TI 1:18" /><char style="w" strong="G03588">May the</char> <char style="w" strong="G02962">Lord</char> <char style="w" strong="G01325">grant</char> <char style="w" strong="G00846">Onesiphorus</char> <char style="w" strong="G02962">His</char> <char style="w" strong="G01656">mercy</char> <char style="w" strong="G01722">on</char> <char style="w" strong="G01565">that</char> <char style="w" strong="G02250">day</char>. <char style="w" strong="G04771">You</char> <char style="w" strong="G01097">know</char> <char style="w" strong="G00957">very well</char> <char style="w" strong="G03745">how much</char> <char style="w" strong="G01247">he ministered to me</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G02181">Ephesus</char>.<verse eid="2TI 1:18" /></para>
