  <para style="p">
    <verse number="12" style="v" sid="2TI 1:12" /><char style="w" strong="G01223">For</char> <char style="w" strong="G03739">this</char> <char style="w" strong="G00156">reason</char>, <char style="w" strong="G02532">even though</char> <char style="w" strong="G03958">I suffer</char> <char style="w" strong="G03778">as I do</char>, <char style="w" strong="G01870">I am not ashamed</char>; <char style="w" strong="G01063">for</char> <char style="w" strong="G01492">I know</char> <char style="w" strong="G03739">whom</char> <char style="w" strong="G04100">I have believed</char>, <char style="w" strong="G02532">and</char> <char style="w" strong="G03982">I am convinced</char> <char style="w" strong="G03754">that</char> <char style="w" strong="G01510">He is</char> <char style="w" strong="G01415">able</char> <char style="w" strong="G05442">to guard</char> <char style="w" strong="G03588">what</char> <char style="w" strong="G03866">I have entrusted to Him</char><note caller="+" style="f"><char style="fr" closed="false">1:12 </char><char style="ft" closed="false">Or </char><char style="fqa" closed="false">what He has entrusted to me</char></note> <char style="w" strong="G01519">for</char> <char style="w" strong="G01565">that</char> <char style="w" strong="G02250">day</char>.<verse eid="2TI 1:12" /></para>
  <para style="s1">Holding to Sound Teaching</para>
  <para style="p">
