  <para style="p" vid="MAT 17:26">
    <char style="wj">“<char style="w" strong="G00686">Then</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G05207">sons</char> <char style="w" strong="G01510">are</char> <char style="w" strong="G01658">exempt</char>,”</char> <char style="w" strong="G02424">Jesus</char> <char style="w" strong="G05346">said</char> <char style="w" strong="G00846">to him</char>. <verse eid="MAT 17:26" /><verse number="27" style="v" sid="MAT 17:27" /><char style="wj">“<char style="w" strong="G01161">But</char> <char style="w" strong="G02443">so that</char> <char style="w" strong="G04624">we may not offend</char> <char style="w" strong="G00846">them</char>, <char style="w" strong="G04198">go</char> <char style="w" strong="G01519">to</char> <char style="w" strong="G02281">the sea</char>, <char style="w" strong="G00906">cast</char> <char style="w" strong="G00044">a hook</char>, <char style="w" strong="G02532">and</char> <char style="w" strong="G00142">take</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G04412">first</char> <char style="w" strong="G02486">fish</char> <char style="w" strong="G00305">you catch</char>. <char style="w" strong="G02532">When</char> <char style="w" strong="G00455">you open</char> <char style="w" strong="G00846">its</char> <char style="w" strong="G04750">mouth</char>, <char style="w" strong="G02147">you will find</char> <char style="w" strong="G04715">a four-drachma coin</char>.<note caller="+" style="f"><char style="fr" closed="false">17:27 </char><char style="ft" closed="false">Greek </char><char style="fqa" closed="false">a stater</char><char style="ft" closed="false">; that is, a silver coin worth approximately one shekel</char></note> <char style="w" strong="G02983">Take it</char> <char style="w" strong="G01565">and</char> <char style="w" strong="G01325">give it</char> <char style="w" strong="G00846">to them</char> <char style="w" strong="G00473">for</char> <char style="w" strong="G01473">My tax</char> <char 