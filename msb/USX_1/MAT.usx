  <para style="p">
    <verse number="37" style="v" sid="MAT 23:37" />
    <char style="wj"><char style="w" strong="G02419">O Jerusalem</char>, <char style="w" strong="G02419">Jerusalem</char>, <char style="w" strong="G03588">who</char> <char style="w" strong="G00615">kills</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G04396">prophets</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G03036">stones</char> <char style="w" strong="G03588">those</char> <char style="w" strong="G00649">sent</char> <char style="w" strong="G04314">to</char> <char style="w" strong="G00846">her</char>, <char style="w" strong="G04212">how often</char> <char style="w" strong="G02309">I have longed</char> <char style="w" strong="G01996">to gather</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G05043">children together</char>, <char style="w" strong="G05158">as</char> <char style="w" strong="G03733">a hen</char> <char style="w" strong="G01996">gathers</char> <char style="w" strong="G01438">her</char> <char style="w" strong="G03556">chicks</char> <char style="w" strong="G05259">under</char> <char style="w" strong="G03588">her</char> <char style="w" strong="G04420">wings</char>, <char style="w" strong="G02532">but</char> <char style="w" strong="G02309">you were unwilling</char>! </char> <verse eid="MAT 23:37" /><verse number="38" style="v" sid="MAT 23:38" /><char style="wj"><char style="w" strong="G03708">Look</char>, <char style="w" strong="G04771">your</char> <char style="w" strong="G03624">house</char> <char style="w" strong="G00863">is left</char> <char style="w" strong="G04771">to you</char> <char style="w" strong="G02048">desolate</char>.<note caller="+" style="f"><char style="fr" closed="false">23:38 </char><char style="ft" closed="false">NE and WH do not include </char><char style="fqa" closed="false">desolate</char><char style="ft" closed="false">.</char></note> </char> <verse eid="MAT 23:38" /><verse number="39" style="v" sid="MAT 23:39" /><char style="wj"><char style="w" strong="G01063">For</char> <char style="w" strong="G03004">I tell</char> <char style="w" strong="G04771">you that</char> <char style="w" strong="G03708">you will not see</char> <char style="w" strong="G01473">Me</char> <char style="w" strong="G00575">again</char> <char style="w" strong="G02193">until</char> <char style="w" strong="G03004">you say</char>, ‘<char style="w" strong="G02127">Blessed is</char> <char style="w" strong="G03588">He who</char> <char style="w" strong="G02064">comes</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G03686">the name</char> <char style="w" strong="G02962">of the Lord</char>.’<note caller="+" style="f"><char style="fr" closed="false">23:39 </char><char style="xt"><ref loc="PSA 118:26">Psalm 118:26</ref></char></note>”</char><verse eid="MAT 23:39" /></para>
