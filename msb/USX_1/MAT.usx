  <para style="s1">Giving to the Needy</para>
  <para style="r">(<ref loc="DEU 15:7-11">Deuteronomy 15:7–11</ref>)</para>
  <para style="p">
    <verse number="1" style="v" sid="MAT 6:1" />
    <char style="wj">“<char style="w" strong="G04337">Be careful</char> <char style="w" strong="G03361">not</char> <char style="w" strong="G04160">to perform</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G01654">acts of charity</char><note caller="+" style="f"><char style="fr" closed="false">6:1 </char><char style="ft" closed="false">Or </char><char style="fqa" closed="false">alms</char><char style="ft" closed="false">; CT </char><char style="fqa" closed="false">righteous acts</char></note> <char style="w" strong="G01715">before</char> <char style="w" strong="G00444">men</char> <char style="w" strong="G02300">to be seen</char> <char style="w" strong="G00846">by them</char>. <char style="w" strong="G01487">If</char> <char style="w" strong="G01161">you do</char>, <char style="w" strong="G02192">you will have</char> <char style="w" strong="G03756">no</char> <char style="w" strong="G03408">reward</char> <char style="w" strong="G03844">from</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G03962">Father</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G03772">heaven</char>.</char><verse eid="MAT 6:1" /></para>
  <para style="p">
    <verse number="2" style="v" sid="MAT 6:2" />
    <char style="wj"><char style="w" strong="G03767">So</char> <char style="w" strong="G03752">when</char> <char style="w" strong="G04160">you give to the needy</char>, <char style="w" strong="G04537">do not sound a trumpet</char> <char style="w" strong="G01715">before</char> <char style="w" strong="G04771">you</char>, <char style="w" strong="G05618">as</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G05273">hypocrites</char> <char style="w" strong="G04160">do</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G04864">synagogues</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G01722">on</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G04505">streets</char>, <char style="w" strong="G03704">to</char> <char style="w" strong="G01392">be honored</char> <char style="w" strong="G05259">by</char> <char style="w" strong="G00444">men</char>. <char style="w" strong="G00281">Truly</char> <char style="w" strong="G03004">I tell</char> <char style="w" strong="G04771">you</char>, <char style="w" strong="G00568">they already have</char> <char style="w" strong="G00846">their</char> <char style="w" strong="G03408">full reward</char>. </char> <verse eid="MAT 6:2" /><verse number="3" style="v" sid="MAT 6:3" /><char style="wj"><char style="w" strong="G01161">But when</char> <char style="w" strong="G04771">you</char> <char style="w" strong="G04160">give to the needy</char>, <char style="w" strong="G03361">do not let</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G00710">left hand</char> <char style="w" strong="G01097">know</char> <char style="w" strong="G05101">what</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G01188">right hand</char> <char style="w" strong="G04160">is doing</char>, </char> <verse eid="MAT 6:3" /><verse number="4" style="v" sid="MAT 6:4" /><char style="wj"><char style="w" strong="G03704">so that</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G01654">giving</char> <char style="w" strong="G01510">may be</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G02927">secret</char>. <char style="w" strong="G02532">And</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G03962">Father</char>, <char style="w" strong="G00991">who sees</char> <char style="w" strong="G03588">what is done</char> <char style="w" strong="G02927">in secret</char>, <char style="w" strong="G00846">will Himself</char> <char style="w" strong="G00591">reward</char> <char style="w" strong="G04771">you</char> <char style="w" strong="G05318">openly</char>.<note caller="+" style="f"><char style="fr" closed="false">6:4 </char><char style="ft" closed="false">CT and GOC </char><char style="fqa" closed="false">will reward you</char></note></char><verse eid="MAT 6:4" /></para>
  <para style="s1">The Lord’s Prayer</para>
  <para style="r">(<ref loc="LUK 11:1-4">Luke 11:1–4</ref>)</para>
  <para style="p">
    <verse number="5" style="v" sid="MAT 6:5" />
    <char style="wj"><char style="w" strong="G02532">And</char> <char style="w" strong="G03752">when</char> <char style="w" strong="G04336">you pray</char>, <char style="w" strong="G01510">do not be</char> <char style="w" strong="G05618">like</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G05273">hypocrites</char>. <char style="w" strong="G03754">For</char> <char style="w" strong="G05368">they love</char> <char style="w" strong="G04336">to pray</char> <char style="w" strong="G02476">standing</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G04864">synagogues</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G01722">on</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G04113">street</char> <char style="w" strong="G01137">corners</char> <char style="w" strong="G05316">to be seen</char> <char style="w" strong="G00444">by men</char>. <char style="w" strong="G00281">Truly</char> <char style="w" strong="G03004">I tell</char> <char style="w" strong="G04771">you</char>, <char style="w" strong="G00568">they already have</char> <char style="w" strong="G00846">their</char> <char style="w" strong="G03408">full reward</char>. </char> <verse eid="MAT 6:5" /><verse number="6" style="v" sid="MAT 6:6" /><char style="wj"><char style="w" strong="G01161">But</char> <char style="w" strong="G03752">when</char> <char style="w" strong="G04336">you pray</char>, <char style="w" strong="G01525">go</char> <char style="w" strong="G01519">into</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G05009">inner room</char>, <char style="w" strong="G02808">shut</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G02374">door</char>, <char style="w" strong="G04336">and pray</char> <char style="w" strong="G03588">to</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G03962">Father</char>, <char style="w" strong="G03588">who is</char> <char style="w" strong="G02927">unseen</char>. <char style="w" strong="G02532">And</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G03962">Father</char>, <char style="w" strong="G03588">who</char> <char style="w" strong="G00991">sees</char> <char style="w" strong="G03588">what is done</char> <char style="w" strong="G02927">in secret</char>, <char style="w" strong="G00591">will reward</char> <char style="w" strong="G04771">you</char> <char style="w" strong="G05318">openly</char>.<note caller="+" style="f"><char style="fr" closed="false">6:6 </char><char style="ft" closed="false">CT </char><char style="fqa" closed="false">will reward you</char></note></char><verse eid="MAT 6:6" /></para>
  <para style="p">
    <verse number="7" style="v" sid="MAT 6:7" />
    <char style="wj"><char style="w" strong="G01161">And</char> <char style="w" strong="G04336">when you pray</char>, <char style="w" strong="G00945">do not babble on</char> <char style="w" strong="G05618">like</char> <char style="w" strong="G01482">pagans</char>, <char style="w" strong="G01063">for</char> <char style="w" strong="G01380">they think</char> <char style="w" strong="G03754">that</char> <char style="w" strong="G01722">by</char> <char style="w" strong="G00846">their</char> <char style="w" strong="G04180">many words</char> <char style="w" strong="G01522">they will be heard</char>. </char> <verse eid="MAT 6:7" /><verse number="8" style="v" sid="MAT 6:8" /><char style="wj"><char style="w" strong="G03361">Do not</char> <char style="w" strong="G03666">be like</char> <char style="w" strong="G00846">them</char>, <char style="w" strong="G01063">for</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G03962">Father</char><note caller="+" style="f"><char style="fr" closed="false">6:8 </char><char style="ft" closed="false">WH </char><char style="fqa" closed="false">God your Father</char></note> <char style="w" strong="G01492">knows</char> <char style="w" strong="G03739">what</char> <char style="w" strong="G02192">you</char> <char style="w" strong="G05532">need</char> <char style="w" strong="G04253">before</char> <char style="w" strong="G04771">you</char> <char style="w" strong="G00154">ask</char> <char style="w" strong="G00846">Him</char>.</char><verse eid="MAT 6:8" /></para>
  <para style="p">
    <verse number="9" style="v" sid="MAT 6:9" />
    <char style="wj"><char style="w" strong="G03767">So then</char>, <char style="w" strong="G03779">this is how</char> <char style="w" strong="G04771">you</char> <char style="w" strong="G04336">should pray</char>:</char></para>
  <para style="q1" vid="MAT 6:9">
    <char style="wj">‘<char style="w" strong="G01473">Our</char> <char style="w" strong="G03962">Father</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G03772">heaven</char>,</char></para>
  <para style="q2" vid="MAT 6:9">
    <char style="wj"><char style="w" strong="G00037">hallowed be</char> <char style="w" strong="G04771">Your</char> <char style="w" strong="G03686">name</char>.</char><verse eid="MAT 6:9" /></para>
  <para style="q1">
    <verse number="10" style="v" sid="MAT 6:10" />
    <char style="wj"><char style="w" strong="G04771">Your</char> <char style="w" strong="G00932">kingdom</char> <char style="w" strong="G02064">come</char>,</char></para>
  <para style="q2" vid="MAT 6:10">
    <char style="wj"><char style="w" strong="G04771">Your</char> <char style="w" strong="G02307">will</char> <char style="w" strong="G01096">be done</char>,</char></para>
  <para style="q2" vid="MAT 6:10">
    <char style="wj"><char style="w" strong="G01909">on</char> <char style="w" strong="G01093">earth</char> <char style="w" strong="G05613">as it is</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G03772">heaven</char>.</char><verse eid="MAT 6:10" /></para>
  <para style="q1">
    <verse number="11" style="v" sid="MAT 6:11" />
    <char style="wj"><char style="w" strong="G01325">Give</char> <char style="w" strong="G01473">us</char> <char style="w" strong="G04594">this day</char> <char style="w" strong="G01473">our</char> <char style="w" strong="G01967">daily</char> <char style="w" strong="G00740">bread</char>.</char><verse eid="MAT 6:11" /></para>
  <para style="q1">
    <verse number="12" style="v" sid="MAT 6:12" />
    <char style="wj"><char style="w" strong="G02532">And</char> <char style="w" strong="G00863">forgive</char> <char style="w" strong="G01473">us</char> <char style="w" strong="G01473">our</char> <char style="w" strong="G03783">debts</char>,</char></para>
  <para style="q2" vid="MAT 6:12">
    <char style="wj"><char style="w" strong="G05613">as</char> <char style="w" strong="G01473">we</char> <char style="w" strong="G02532">also</char> <char style="w" strong="G00863">forgive</char><note caller="+" style="f"><char style="fr" closed="false">6:12 </char><char style="ft" closed="false">CT </char><char style="fqa" closed="false">have forgiven</char></note> <char style="w" strong="G01473">our</char> <char style="w" strong="G03781">debtors</char>.</char><verse eid="MAT 6:12" /></para>
  <para style="q1">
