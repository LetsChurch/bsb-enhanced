  <para style="p">
    <verse number="37" style="v" sid="MAT 26:37" /><char style="w" strong="G03880">He took with Him</char> <char style="w" strong="G04074">Peter</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G01417">two</char> <char style="w" strong="G05207">sons</char> <char style="w" strong="G02199">of Zebedee</char> <char style="w" strong="G00756">and began</char> <char style="w" strong="G03076">to be sorrowful</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G00085">deeply distressed</char>. <verse eid="MAT 26:37" /><verse number="38" style="v" sid="MAT 26:38" /><char style="w" strong="G05119">Then</char> <char style="w" strong="G02424">Jesus</char> <char style="w" strong="G03004">said</char><note caller="+" style="f"><char style="fr" closed="false">26:38 </char><char style="ft" closed="false">CT </char><char style="fqa" closed="false">Then He said</char></note> <char style="w" strong="G00846">to them</char>, <char style="wj">“<char style="w" strong="G01473">My</char> <char style="w" strong="G05590">soul</char> <char style="w" strong="G01510">is</char> <char style="w" strong="G04036">consumed with sorrow</char> <char style="w" strong="G02193">to the point</char> <char style="w" strong="G02288">of death</char>. <char style="w" strong="G03306">Stay</char> <char style="w" strong="G05602">here</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G01127">keep watch</char> <char style="w" strong="G03326">with</char> <char style="w" strong="G01473">Me</char>.”</char><verse eid="MAT 26:38" /></para>
  <para style="p">
    <verse number="39" style="v" sid="MAT 26:39" /><char style="w" strong="G04334">Going</char> <char style="w" strong="G03398">a little farther</char>, <char style="w" strong="G04098">He fell</char> <char style="w" strong="G04383">facedown</char> <char style="w" strong="G04336">and prayed</char>, <char style="wj">“<char style="w" strong="G01473">My</char> <char style="w" strong="G03962">Father</char>, <char style="w" strong="G01487">if</char> <char style="w" strong="G01510">it is</char> <char style="w" strong="G01415">possible</char>, <char style="w" strong="G03778">let this</char> <char style="w" strong="G04221">cup</char> <char style="w" strong="G03928">pass</char> <char style="w" strong="G00575">from</char> <char style="w" strong="G01473">Me</char>. <char style="w" strong="G04133">Yet</char> <char style="w" strong="G03756">not</char> <char style="w" strong="G05613">as</char> <char style="w" strong="G01473">I</char> <char style="w" strong="G02309">will</char>, <char style="w" strong="G00235">but</char> <char style="w" strong="G05613">as</char> <char style="w" strong="G04771">You will</char>.”</char><verse eid="MAT 26:39" /></para>
  <para style="p">
