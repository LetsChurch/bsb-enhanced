  <para style="p">
    <verse number="37" style="v" sid="MAT 9:37" /><char style="w" strong="G05119">Then</char> <char style="w" strong="G03004">He said</char> <char style="w" strong="G03588">to</char> <char style="w" strong="G00846">His</char> <char style="w" strong="G03101">disciples</char>, <char style="wj">“<char style="w" strong="G03588">The</char> <char style="w" strong="G02326">harvest</char> <char style="w" strong="G04183">is plentiful</char>, <char style="w" strong="G01161">but</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G02040">workers</char> <char style="w" strong="G03641">are few</char>. </char> <verse eid="MAT 9:37" /><verse number="38" style="v" sid="MAT 9:38" /><char style="wj"><char style="w" strong="G01189">Ask</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G02962">Lord</char> <char style="w" strong="G03588">of the</char> <char style="w" strong="G02326">harvest</char>, <char style="w" strong="G03767">therefore</char>, <char style="w" strong="G01544">to send out</char> <char style="w" strong="G02040">workers</char> <char style="w" strong="G01519">into</char> <char style="w" strong="G00846">His</char> <char style="w" strong="G02326">harvest</char>.”</char><verse eid="MAT 9:38" /></para>
