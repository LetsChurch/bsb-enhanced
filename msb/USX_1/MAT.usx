    <char style="wj"><char style="w" strong="G03759">Woe</char> <char style="w" strong="G04771">to you</char>, <char style="w" strong="G01122">scribes</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G05330">Pharisees</char>, <char style="w" strong="G05273">you hypocrites</char>! <char style="w" strong="G00586">You pay tithes of</char> <char style="w" strong="G02238">mint</char>, <char style="w" strong="G00432">dill</char>, <char style="w" strong="G02532">and</char> <char style="w" strong="G02951">cumin</char>. <char style="w" strong="G02532">But</char> <char style="w" strong="G00863">you have disregarded</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G00926">weightier matters</char> <char style="w" strong="G03588">of the</char> <char style="w" strong="G03551">law</char>: <char style="w" strong="G02920">justice</char>, <char style="w" strong="G01656">mercy</char>, <char style="w" strong="G02532">and</char> <char style="w" strong="G04102">faithfulness</char>. <char style="w" strong="G01163">You should have</char> <char style="w" strong="G04160">practiced</char> <char style="w" strong="G03778">the latter</char>, <char style="w" strong="G03361">without</char> <char style="w" strong="G00863">neglecting</char> <char style="w" strong="G02548">the former</char>. </char> <verse eid="MAT 23:23" /><verse number="24" style="v" sid="MAT 23:24" /><char style="wj"><char style="w" strong="G05185">You blind</char> <char style="w" strong="G03595">guides</char>! <char style="w" strong="G01368">You strain out</char> <char style="w" strong="G02971">a gnat</char> <char style="w" strong="G01161">but</char> <char style="w" strong="G02666">swallow</char> <char style="w" strong="G02574">a camel</char>.<note caller="+" style="f"><char style="fr" closed="false">23:24 </char><char style="ft" closed="false">See </char><char style="xt"><ref loc="LEV 11:4">Leviticus 11:4</ref></char> and Leviticus 11:23, where camels and gnats are both forbidden