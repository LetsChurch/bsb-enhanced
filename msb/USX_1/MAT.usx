    <char style="wj">“<char style="w" strong="G00281">Truly</char> <char style="w" strong="G03004">I tell</char> <char style="w" strong="G04771">you</char>,”</char> <char style="w" strong="G02424">Jesus</char> <char style="w" strong="G05346">declared</char>, <char style="wj">“<char style="w" strong="G03778">this</char> <char style="w" strong="G03588">very</char> <char style="w" strong="G03571">night</char>, <char style="w" strong="G04250">before</char> <char style="w" strong="G00220">the rooster</char> <char style="w" strong="G05455">crows</char>, <char style="w" strong="G00533">you will deny</char> <char style="w" strong="G01473">Me</char> <char style="w" strong="G05151">three times</char>.”</char><verse eid="MAT 26:34" /></para>
