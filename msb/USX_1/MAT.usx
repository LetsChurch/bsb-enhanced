    <char style="wj"><char style="w" strong="G05119">Then</char> <char style="w" strong="G03860">they will deliver</char> <char style="w" strong="G04771">you</char> <char style="w" strong="G01519">over to</char> <char style="w" strong="G02347">be persecuted</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G00615">killed</char>, <char style="w" strong="G02532">and</char> <char style="w" strong="G01510">you will be</char> <char style="w" strong="G03404">hated</char> <char style="w" strong="G05259">by</char> <char style="w" strong="G03956">all</char> <char style="w" strong="G01484">nations</char> <char style="w" strong="G01223">because of</char> <char style="w" strong="G01473">My</char> <char style="w" strong="G03686">name</char>. </char> <verse eid="MAT 24:9" /><verse number="10" style="v" sid="MAT 24:10" /><char style="wj"><char style="w" strong="G05119">At that time</char> <char style="w" strong="G04183">many</char> <char style="w" strong="G04624">will fall away</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G03860">will betray</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G03404">hate</char> <char style="w" strong="G00240">one another</char>, </char> <verse eid="MAT 24:10" /><verse number="11" style="v" sid="MAT 24:11" /><char style="wj"><char style="w" strong="G02532">and</char> <char style="w" strong="G04183">many</char> <char style="w" strong="G05578">false prophets</char> <char style="w" strong="G01453">will arise</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G04105">deceive</char> <char style="w" strong="G04183">many</char>.</char><verse eid="MAT 24:11" /></para>
  <para style="p">
    <verse number="12" style="v" sid="MAT 24:12" />
    <char style="wj"><char style="w" strong="G01223">Because of</char> <char style="w" strong="G04129">the multiplication</char> <char style="w" strong="G00458">of wickedness</char>, <char style="w" strong="G03588">the</char> <char style="w" strong="G00026">love</char> <char style="w" strong="G03588">of</char> <char style="w" strong="G04183">most</char> <char style="w" strong="G05594">will grow cold</char>. </char> <verse eid="MAT 24:12" /><verse number="13" style="v" sid="MAT 24:13" /><char style="wj"><char style="w" strong="G01161">But</char> <char style="w" strong="G03588">the one who</char> <char style="w" strong="G05278">perseveres</char> <char style="w" strong="G01519">to</char> <char style="w" strong="G05056">the end</char> <char style="w" strong="G04982">will be saved</char>.</char><verse eid="MAT 24:13" /></para>
  <para style="p">
    <verse number="14" style="v" sid="MAT 24:14" />
    <char style="wj"><char style="w" strong="G02532">And</char> <char style="w" strong="G03778">this</char> <char style="w" strong="G02098">gospel</char> <char style="w" strong="G03588">of the</char> <char style="w" strong="G00932">kingdom</char> <char style="w" strong="G02784">will be preached</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G03650">all</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G03625">world</char> <char style="w" strong="G01519">as</char> <char style="w" strong="G03142">a testimony</char> <char style="w" strong="G03956">to all</char> <char style="w" strong="G01484">nations</char>, <char style="w" strong="G02532">and</char> <char style="w" strong="G05119">then</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G05056">end</char> <char style="w" strong="G02240">will come</char>.</char><verse eid="MAT 24:14" /></para>
