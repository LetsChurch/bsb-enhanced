  <para style="s1">Temple Destruction and Other Signs</para>
  <para style="r">(<ref loc="MRK 13:1-8">Mark 13:1–8</ref>; <ref loc="LUK 21:5-9">Luke 21:5–9</ref>)</para>
  <para style="p">
    <verse number="1" style="v" sid="MAT 24:1" /><char style="w" strong="G02532">As</char> <char style="w" strong="G02424">Jesus</char> <char style="w" strong="G01831">left</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G02411">temple</char> <char style="w" strong="G04198">and was walking away</char>, <char style="w" strong="G00846">His</char> <char style="w" strong="G03101">disciples</char> <char style="w" strong="G04334">came up to Him</char> <char style="w" strong="G01925">to point out</char> <char style="w" strong="G02411">its</char> <char style="w" strong="G03619">buildings</char>.<verse eid="MAT 24:1" /></para>
  <para style="p">
    <verse number="2" style="v" sid="MAT 24:2" />
    <char style="wj">“<char style="w" strong="G00991">Do you see</char> <char style="w" strong="G03956">all</char> <char style="w" strong="G03778">these things</char>?”</char> <char style="w" strong="G02424">Jesus</char> <char style="w" strong="G03004">replied</char>.<note caller="+" style="f"><char style="fr" closed="false">24:2 </char><char style="ft" closed="false">CT </char><char style="fqa" closed="false">He replied </char></note><char style="wj">“<char style="w" strong="G00281">Truly</char> <char style="w" strong="G03004">I tell</char> <char style="w" strong="G04771">you</char>, <char style="w" strong="G03361">not</char> <char style="w" strong="G03037">one stone</char> <char style="w" strong="G05602">here</char> <char style="w" strong="G00863">will be left</char> <char style="w" strong="G01909">on</char> <char style="w" strong="G03037">another</char>; <char style="w" strong="G03739">every one</char> <char style="w" strong="G02647">will be thrown down</char>.”</char><verse eid="MAT 24:2" /></para>
  <para style="p">
    <verse number="3" style="v" sid="MAT 24:3" /><char style="w" strong="G01161">While</char> <char style="w" strong="G00846">Jesus</char> <char style="w" strong="G02521">was sitting</char> <char style="w" strong="G01909">on</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G03735">Mount</char> <char style="w" strong="G01636">of Olives</char>, <char style="w" strong="G03588">the</char> <char style="w" strong="G03101">disciples</char> <char style="w" strong="G04334">came to</char> <char style="w" strong="G00846">Him</char> <char style="w" strong="G02398">privately</char>. “<char style="w" strong="G03004">Tell</char> <char style="w" strong="G01473">us</char>,” <char style="w" strong="G03004">they said</char>, “<char style="w" strong="G04219">when will</char> <char style="w" strong="G03778">these things</char> <char style="w" strong="G01510">happen</char>, <char style="w" strong="G02532">and</char> <char style="w" strong="G05101">what will be</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G04592">sign</char> <char style="w" strong="G04674">of Your</char> <char style="w" strong="G03952">coming</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G04930">of the end</char> <char style="w" strong="G03588">of the</char> <char style="w" strong="G00165">age</char>?”<verse eid="MAT 24:3" /></para>
  <para style="p">
    <verse number="4" style="v" sid="MAT 24:4" /><char style="w" strong="G02424">Jesus</char> <char style="w" strong="G00611">answered</char>, <char style="wj">“<char style="w" strong="G00991">See to it</char> <char style="w" strong="G03361">that no one</char> <char style="w" strong="G04105">deceives</char> <char style="w" strong="G04771">you</char>. </char> <verse eid="MAT 24:4" /><verse number="5" style="v" sid="MAT 24:5" /><char style="wj"><char style="w" strong="G01063">For</char> <char style="w" strong="G04183">many</char> <char style="w" strong="G02064">will come</char> <char style="w" strong="G01909">in</char> <char style="w" strong="G01473">My</char> <char style="w" strong="G03686">name</char>, <char style="w" strong="G03004">claiming</char>, ‘<char style="w" strong="G01473">I</char> <char style="w" strong="G01510">am</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G05547">Christ</char>,’ <char style="w" strong="G02532">and</char> <char style="w" strong="G04105">will deceive many</char>. </char> <verse eid="MAT 24:5" /><verse number="6" style="v" sid="MAT 24:6" /><char style="wj"><char style="w" strong="G03195">You will</char> <char style="w" strong="G00191">hear</char><note caller="+" style="f"><char style="fr" closed="false">24:6 </char><char style="ft" closed="false">F35 </char><char style="fqa" closed="false">You will be concerned when you hear</char></note> <char style="w" strong="G04171">of wars</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G00189">rumors</char> <char style="w" strong="G04171">of wars</char>, <char style="w" strong="G03708">but see to it</char> <char style="w" strong="G02360">that you are not alarmed</char>. <char style="w" strong="G03956">All these things</char><note caller="+" style="f"><char style="fr" closed="false">24:6 </char><char style="ft" closed="false">CT </char><char style="fqa" closed="false">These things</char></note> <char style="w" strong="G01163">must</char> <char style="w" strong="G01096">happen</char>, <char style="w" strong="G00235">but</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G05056">end</char> <char style="w" strong="G01510">is</char> <char style="w" strong="G03768">still to come</char>. </char> <verse eid="MAT 24:6" /><verse number="7" style="v" sid="MAT 24:7" /><char style="wj"><char style="w" strong="G01484">Nation</char> <char style="w" strong="G01453">will rise</char> <char style="w" strong="G01909">against</char> <char style="w" strong="G01484">nation</char>, <char style="w" strong="G02532">and</char> <char style="w" strong="G00932">kingdom</char> <char style="w" strong="G01909">against</char> <char style="w" strong="G00932">kingdom</char>. <char style="w" strong="G01510">There will be</char> <char style="w" strong="G03042">famines</char>, <char style="w" strong="G03061">pestilences</char>,<note caller="+" style="f"><char style="fr" closed="false">24:7 </char><char style="ft" closed="false">CT does not include </char><char style="fqa" closed="false">pestilences</char><char style="ft" closed="false">.</char></note> <char style="w" strong="G02532">and</char> <char style="w" strong="G04578">earthquakes</char> <char style="w" strong="G02596">in</char> <char style="w" strong="G05117">various places</char>. </char> <verse eid="MAT 24:7" /><verse number="8" style="v" sid="MAT 24:8" /><char style="wj"><char style="w" strong="G03956">All</char> <char style="w" strong="G03778">these are</char> <char style="w" strong="G00746">the beginning</char> <char style="w" strong="G05604">of birth pains</char>.</char><verse eid="MAT 24:8" /></para>
