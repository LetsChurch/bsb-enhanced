  <para style="p">
    <verse number="2" style="v" sid="MAT 18:2" /><char style="w" strong="G02424">Jesus</char> <char style="w" strong="G04341">invited</char> <char style="w" strong="G03813">a little child</char> <char style="w" strong="G02476">to stand</char> <char style="w" strong="G03319">among them</char>. <verse eid="MAT 18:2" /><verse number="3" style="v" sid="MAT 18:3" /><char style="wj">“<char style="w" strong="G00281">Truly</char> <char style="w" strong="G03004">I tell</char> <char style="w" strong="G04771">you</char>,”</char> <char style="w" strong="G03004">He said</char>, <char style="wj">“<char style="w" strong="G01437">unless</char> <char style="w" strong="G04762">you change</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G01096">become</char> <char style="w" strong="G05613">like</char> <char style="w" strong="G03813">little children</char>, <char style="w" strong="G01525">you will never enter</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G00932">kingdom</char> <char style="w" strong="G03588">of</char> <char style="w" strong="G03772">heaven</char>. </char> <verse eid="MAT 18:3" /><verse number="4" style="v" sid="MAT 18:4" /><char style="wj"><char style="w" strong="G03767">Therefore</char>, <char style="w" strong="G03748">whoever</char> <char style="w" strong="G05013">humbles</char> <char style="w" strong="G01438">himself</char> <char style="w" strong="G05613">like</char> <char style="w" strong="G03778">this</char> <char style="w" strong="G03813">little child</char> <char style="w" strong="G01510">is</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G03173">greatest</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G00932">kingdom</char> <char style="w" strong="G03588">of</char> <char style="w" strong="G03772">heaven</char>. </char> <verse eid="MAT 18:4" /><verse number="5" style="v" sid="MAT 18:5" /><char style="wj"><char style="w" strong="G02532">And</char> <char style="w" strong="G03739">whoever</char> <char style="w" strong="G01209">welcomes</char> <char style="w" strong="G01520">a</char> <char style="w" strong="G03813">little child</char> <char style="w" strong="G05108">like this</char> <char style="w" strong="G01909">in</char> <char style="w" strong="G01473">My</char> <char style="w" strong="G03686">name</char> <char style="w" strong="G01209">welcomes</char> <char style="w" strong="G01473">Me</char>.</char><verse eid="MAT 18:5" /></para>
