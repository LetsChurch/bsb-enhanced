    <char style="wj"><char style="w" strong="G01510">Be</char> <char style="w" strong="G05046">perfect</char>, <char style="w" strong="G03767">therefore</char>, <char style="w" strong="G05618">as</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G03962">Father</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G03772">heaven</char><note caller="+" style="f"><char style="fr" closed="false">5:48 </char><char style="ft" closed="false">CT </char><char style="fqa" closed="false">heavenly Father</char></note> <char style="w" strong="G01510">is</char> <char style="w" strong="G05046">perfect</char>.’’</char><verse eid="MAT 5:48" /></para>
