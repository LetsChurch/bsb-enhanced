  <para style="s1">The Victory of the Lamb</para>
  <para style="p">
    <verse number="14" style="v" sid="REV 17:14" /><char style="w" strong="G03778">They</char> <char style="w" strong="G04170">will make war</char> <char style="w" strong="G03326">against</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G00721">Lamb</char>, <char style="w" strong="G02532">and</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G00721">Lamb</char> <char style="w" strong="G03528">will triumph over</char> <char style="w" strong="G00846">them</char>, <char style="w" strong="G03754">because</char> <char style="w" strong="G01510">He is</char> <char style="w" strong="G02962">Lord</char> <char style="w" strong="G02962">of lords</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G00935">King</char> <char style="w" strong="G00935">of kings</char>; <char style="w" strong="G02532">and</char> <char style="w" strong="G03326">He will be accompanied by</char> <char style="w" strong="G00846">His</char> <char style="w" strong="G02822">called</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G01588">chosen</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G04103">faithful ones</char>.”<verse eid="REV 17:14" /></para>
  <para style="p">
