  <para style="lf" vid="REV 3:7">
    <char style="wj"><char style="w" strong="G03592">These are</char> <char style="w" strong="G03004">the words</char> <char style="w" strong="G03588">of the One who is</char> <char style="w" strong="G00040">holy</char> <char style="w" strong="G03588">and</char> <char style="w" strong="G00228">true</char>, <char style="w" strong="G03588">who</char> <char style="w" strong="G02192">holds</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G02807">key</char> <char style="w" strong="G01138">of David</char>. <char style="w" strong="G03588">What</char> <char style="w" strong="G00455">He opens</char> <char style="w" strong="G03762">no one</char> <char style="w" strong="G02808">can shut</char> (<char style="w" strong="G00846">except</char> <char style="w" strong="G03588">Him who</char> <char style="w" strong="G00455">opens</char>) <char style="w" strong="G02532">and</char> <char style="w" strong="G03762">no one</char> <char style="w" strong="G00455">can open</char>.<note caller="+" style="f"><char style="fr" closed="false">3:7 </char><char style="ft" closed="false">See </char><char style="xt"><ref loc="ISA 22:22">Isaiah 22:22</ref></char>; CT and TR <char style="fqa" closed="false">What He opens no one can shut, and what He shuts no one can open.</char></note></char><verse eid="REV 3:7" /></para>
