  <para style="p">
    <verse number="12" style="v" sid="REV 9:12" /><char style="w" strong="G03588">The</char> <char style="w" strong="G01520">first</char> <char style="w" strong="G03759">woe</char> <char style="w" strong="G00565">has passed</char>. <char style="w" strong="G03708">Behold</char>, <char style="w" strong="G01417">two</char> <char style="w" strong="G03759">woes</char> <char style="w" strong="G02089">are still</char> <char style="w" strong="G02064">to follow</char>.<verse eid="REV 9:12" /></para>
