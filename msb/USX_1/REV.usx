  <para style="p">
    <verse number="3" style="v" sid="REV 9:3" /><char style="w" strong="G02532">And</char> <char style="w" strong="G01537">out of</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G02586">smoke</char>, <char style="w" strong="G00200">locusts</char> <char style="w" strong="G01831">descended on</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G01093">earth</char>, <char style="w" strong="G02532">and</char> <char style="w" strong="G00846">they</char> <char style="w" strong="G01325">were given</char> <char style="w" strong="G01849">power</char> <char style="w" strong="G05613">like</char> <char style="w" strong="G01849">that of</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G04651">scorpions</char> <char style="w" strong="G03588">of the</char> <char style="w" strong="G01093">earth</char>. <verse eid="REV 9:3" /><verse number="4" style="v" sid="REV 9:4" /><char style="w" strong="G00846">They</char> <char style="w" strong="G02046">were told</char> <char style="w" strong="G03361">not</char> <char style="w" strong="G00091">to harm</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G05528">grass</char> <char style="w" strong="G03588">of the</char> <char style="w" strong="G01093">earth</char> <char style="w" strong="G03761">or</char> <char style="w" strong="G03956">any</char> <char style="w" strong="G05515">plant</char> <char style="w" strong="G03761">or</char> <char style="w" strong="G01186">tree</char>, <char style="w" strong="G01487">but only</char> <char style="w" strong="G03588">those</char> <char style="w" strong="G03748">who</char> <char style="w" strong="G02192">did not have</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G04973">seal</char> <char style="w" strong="G02316">of God</char> <char style="w" strong="G01909">on</char> <char style="w" strong="G00846">their</char> <char style="w" strong="G03359">foreheads</char>. <verse eid="REV 9:4" /><v