    <verse number="22" style="v" sid="COL 3:22" /><char style="w" strong="G01401">Slaves</char>, <char style="w" strong="G05219">obey</char> <char style="w" strong="G03588">your</char> <char style="w" strong="G02596">earthly</char> <char style="w" strong="G02962">masters</char> <char style="w" strong="G02596">in</char> <char style="w" strong="G03956">everything</char>, <char style="w" strong="G03361">not only</char> <char style="w" strong="G00441">to please them</char> <char style="w" strong="G03787">while they are watching</char>, <char style="w" strong="G00235">but</char> <char style="w" strong="G01722">with</char> <char style="w" strong="G00572">sincerity</char> <char style="w" strong="G02588">of heart</char> <char style="w" strong="G05399">and fear</char> <char style="w" strong="G03588">of</char> <char style="w" strong="G02316">God</char>.<note caller="+" style="f"><char style="fr" closed="false">3:22 </char><char style="ft" closed="false">CT </char><char style="fqa" closed="false">of the Lord</char></note><verse eid="COL 3:22" /></para>
  <para style="p">
    <verse number="23" style="v" sid="COL 3:23" /><char style="w" strong="G02532">And</char><note caller="+" style="f"><char style="fr" closed="false">3:23 </char><char style="ft" closed="false">CT does not include </char><char style="fqa" closed="false">And</char><char style="ft" closed="false">.</char></note> <char style="w" strong="G03956">whatever</char> <char style="w" strong="G04160">you do</char>, <char style="w" strong="G02038">work at it</char> <char style="w" strong="G05590">with your whole being</char>, <char style="w" strong="G05613">as for</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G02962">Lord</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G03756">not</char> <char style="w" strong="G00444">for men</char>, <verse eid="COL 3:23" /><verse number="24" style="v" sid="COL 3:24" /><char style="w" strong="G01492">because you know</char> <char style="w" strong="G03754">that</char> <char style="w" strong="G02983">you will receive</char> <char style="w" strong="G02817">an inheritance</char> <char style="w" strong="G00575">from</char> <char style="w" strong="G02962">the Lord</char> <char style="w" strong="G03588">as your</char> <char style="w" strong="G00469">reward</char>. <char style="w" strong="G01063">For</char><note caller="+" style="f"><char style="fr" closed="false">3:24 </char><char style="ft" closed="false">CT does not include </char><char style="fqa" closed="false">For</char><char style="ft" closed="false">.</char></note> <char style="w" strong="G03588">it is the</char> <char style="w" strong="G02962">Lord</char> <char style="w" strong="G05547">Christ</char> <char style="w" strong="G01398">you are serving</char>. <verse eid="COL 3:24" /><verse number="25" style="v" sid="COL 3:25" /><char style="w" strong="G01161">But</char><note caller="+" style="f"><char style="fr" closed="false">3:25 </char><char style="ft" closed="false">CT literal </char><char style="fqa" closed="false">For</char></note> <char style="w" strong="G03588">whoever</char> <char style="w" strong="G00091">does wrong</char> <char style="w" strong="G02865">will be repaid for</char> <char style="w" strong="G00091">his wrong</char>, <char style="w" strong="G02532">and</char> <char style="w" strong="G01510">there is</char> <char style="w" strong="G03756">no</char> <char style="w" strong="G04382">favoritism</char>.<verse eid="COL 3:25" /></para>
  <chapter eid="COL 3" />
  <chapter number="4" style="c" sid="COL 4" />
  <para style="s1">Prayerful Speech and Actions</para>
  <para style="p">
    <verse number="1" style="v" sid="COL 4:1" /><char style="w" strong="G02962">Masters</char>, <char style="w" strong="G03930">supply</char> <char style="w" strong="G03588">your</char> <char style="w" strong="G01401">slaves</char> <char style="w" strong="G03588">with what</char> <char style="w" strong="G01342">is right</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G02471">fair</char>, <char style="w" strong="G01492">since you know</char> <char style="w" strong="G03754">that</char> <char style="w" strong="G04771">you</char> <char style="w" strong="G02532">also</char> <char style="w" strong="G02192">have</char> <char style="w" strong="G02962">a Master</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G03772">heaven</char>.<verse eid="COL 4:1" /></para>
  <para style="p">
    <verse number="2" style="v" sid="COL 4:2" /><char style="w" strong="G04342">Devote yourselves</char> <char style="w" strong="G03588">to</char> <char style="w" strong="G04335">prayer</char>, <char style="w" strong="G01127">being watchful</char> <char style="w" strong="G01722">and</char> <char style="w" strong="G02169">thankful</char>, <verse eid="COL 4:2" /><verse number="3" style="v" sid="COL 4:3" /><char style="w" strong="G00260">as</char> <char style="w" strong="G04336">you pray</char> <char style="w" strong="G02532">also</char> <char style="w" strong="G04012">for</char> <char style="w" strong="G01473">us</char>, <char style="w" strong="G02443">that</char> <char style="w" strong="G02316">God</char> <char style="w" strong="G00455">may open</char> <char style="w" strong="G01473">to us</char> <char style="w" strong="G02374">a door</char> <char style="w" strong="G03588">for the</char> <char style="w" strong="G03056">word</char>, <char style="w" strong="G02980">so that we may proclaim</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G03466">mystery</char> <char style="w" strong="G05547">of Christ</char>, <char style="w" strong="G01223">for</char> <char style="w" strong="G03739">which</char> <char style="w" strong="G01210">I am in chains</char>. <verse eid="COL 4:3" /><verse number="4" style="v" sid="COL 4:4" /><char style="w" strong="G02443">Pray that</char> <char style="w" strong="G05319">I may declare it clearly</char>, <char style="w" strong="G05613">as</char> <char style="w" strong="G01473">I</char> <char style="w" strong="G01163">should</char>.<verse eid="COL 4:4" /></para>
  <para style="p">
    <verse number="5" style="v" sid="COL 4:5" /><char style="w" strong="G04043">Act</char> <char style="w" strong="G04678">wisely</char> <char style="w" strong="G04314">toward</char> <char style="w" strong="G01854">outsiders</char>, <char style="w" strong="G01805">redeeming</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G02540">time</char>. <verse eid="COL 4:5" /><verse number="6" style="v" sid="COL 4:6" /><char style="w" strong="G04771">Let your</char> <char style="w" strong="G03056">speech</char> <char style="w" strong="G03842">always be</char> <char style="w" strong="G05485">gracious</char>, <char style="w" strong="G00741">seasoned</char> <char style="w" strong="G00217">with salt</char>, <char style="w" strong="G01492">so that you may know</char> <char style="w" strong="G04459">how</char> <char style="w" strong="G00611">to answer</char> <char style="w" strong="G01538">everyone</char>.<verse eid="COL 4:6" /></para>
  <para style="s1">Greetings from Paul’s Fellow Workers</para>
  <para style="r">(<ref loc="ROM 16:21-23">Romans 16:21–23</ref>)</para>
  <para style="p">
    <verse number="7" style="v" sid="COL 4:7" /><char style="w" strong="G05190">Tychicus</char> <char style="w" strong="G01107">will tell</char> <char style="w" strong="G04771">you</char> <char style="w" strong="G03956">all</char> <char style="w" strong="G03588">the news</char> <char style="w" strong="G02596">about</char> <char style="w" strong="G01473">me</char>. <char style="w" strong="G03588">He is</char> <char style="w" strong="G00027">a beloved</char> <char style="w" strong="G00080">brother</char>, <char style="w" strong="G04103">a faithful</char> <char style="w" strong="G01249">minister</char>, <char style="w" strong="G02532">and</char> <char style="w" strong="G04889">a fellow servant</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G02962">the Lord</char>. <verse eid="COL 4:7" /><verse number="8" style="v" sid="COL 4:8" /><char style="w" strong="G03992">I have sent</char> <char style="w" strong="G03739">him</char> <char style="w" strong="G04314">to</char> <char style="w" strong="G04771">you</char> <char style="w" strong="G01519">for</char> <char style="w" strong="G00846">this very</char> <char style="w" strong="G03778">purpose</char>, <char style="w" strong="G02443">that</char> <char style="w" strong="G01097">he may know</char> <char style="w" strong="G04012">about</char> <char style="w" strong="G04771">you</char>,<note caller="+" style="f"><char style="fr" closed="false">4:8 </char><char style="ft" closed="false">CT </char><char style="fqa" closed="false">you may know about us</char></note> <char style="w" strong="G02532">and that</char> <char style="w" strong="G03870">he may encourage</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G02588">hearts</char>. <verse eid="COL 4:8" /><verse number="9" style="v" sid="COL 4:9" /><char style="w" strong="G04862">With him I am sending</char> <char style="w" strong="G03682">Onesimus</char>, <char style="w" strong="G03588">our</char> <char style="w" strong="G04103">faithful</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G00027">beloved</char> <char style="w" strong="G00080">brother</char>, <char style="w" strong="G03739">who</char> <char style="w" strong="G01510">is</char> <char style="w" strong="G01537">one of</char> <char style="w" strong="G04771">you</char>. <char style="w" strong="G01107">They will tell</char> <char style="w" strong="G04771">you about</char> <char style="w" strong="G03956">everything</char> <char style="w" strong="G05602">here</char>.<verse eid="COL 4:9" /></para>
  <para style="p">
    <verse number="10" style="v" sid="COL 4:10" /><char style="w" strong="G01473">My</char> <char style="w" strong="G04869">fellow prisoner</char> <char style="w" strong="G00708">Aristarchus</char> <char style="w" strong="G00782">sends you greetings</char>, <char style="w" strong="G02532">as does</char> <char style="w" strong="G03138">Mark</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G00431">cousin</char> <char style="w" strong="G00921">of Barnabas</char>. <char style="w" strong="G02983">You have already received</char> <char style="w" strong="G01785">instructions</char> <char style="w" strong="G04012">about</char> <char style="w" strong="G03739">him</char>: <char style="w" strong="G01437">If</char> <char style="w" strong="G02064">he comes</char> <char style="w" strong="G04314">to</char> <char style="w" strong="G04771">you</char>, <char style="w" strong="G01209">welcome</char> <char style="w" strong="G00846">him</char>. <verse eid="COL 4:10" /><verse number="11" style="v" sid="COL 4:11" /><char style="w" strong="G02424">Jesus</char>, <char style="w" strong="G03004">who is called</char> <char style="w" strong="G02459">Justus</char>, <char style="w" strong="G02532">also sends greetings</char>. <char style="w" strong="G03778">These</char> <char style="w" strong="G01510">are</char> <char style="w" strong="G03441">the only</char> <char style="w" strong="G04061">Jews</char> <char style="w" strong="G01537">among</char> <char style="w" strong="G03588">my</char> <char style="w" strong="G04904">fellow workers</char> <char style="w" strong="G01519">for</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G00932">kingdom</char> <char style="w" strong="G02316">of God</char>, <char style="w" strong="G03748">and they</char> <char style="w" strong="G01096">have been</char> <char style="w" strong="G03931">a comfort</char> <char style="w" strong="G01473">to me</char>.<verse eid="COL 4:11" /></para>
  <para style="p">
    <verse number="12" style="v" sid="COL 4:12" /><char style="w" strong="G01889">Epaphras</char>, <char style="w" strong="G03588">who is</char> <char style="w" strong="G01537">one of</char> <char style="w" strong="G04771">you</char> <char style="w" strong="G01401">and a servant</char> <char style="w" strong="G05547">of Christ</char>,<note caller="+" style="f"><char style="fr" closed="false">4:12 </char><char style="ft" closed="false">CT </char><char style="fqa" closed="false">of Christ Jesus</char></note> <char style="w" strong="G00782">sends you greetings</char>. <char style="w" strong="G03842">He is always</char> <char style="w" strong="G00075">wrestling</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G04335">prayer</char> <char style="w" strong="G05228">for</char> <char style="w" strong="G04771">you</char>, <char style="w" strong="G02443">so that</char> <char style="w" strong="G02476">you may stand</char> <char style="w" strong="G05046">mature</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G04137">complete</char><note caller="+" style="f"><char style="fr" closed="false">4:12 </char><char style="ft" closed="false">CT </char><char style="fqa" closed="false">mature and fully assured</char></note> <char style="w" strong="G01722">in</char> <char style="w" strong="G03956">the full</char> <char style="w" strong="G02307">will</char> <char style="w" strong="G02316">of God</char>. <verse eid="COL 4:12" /><verse number="13" style="v" sid="COL 4:13" /><char style="w" strong="G01063">For</char> <char style="w" strong="G03140">I testify</char> <char style="w" strong="G00846">about him</char> <char style="w" strong="G03754">that</char> <char style="w" strong="G02192">he has</char> <char style="w" strong="G04183">great</char> <char style="w" strong="G02205">zeal</char><note caller="+" style="f"><char style="fr" closed="false">4:13 </char><char style="ft" closed="false">CT </char><char style="fqa" closed="false">he goes to great pains</char></note> <char style="w" strong="G05228">for</char> <char style="w" strong="G04771">you</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G03588">for those</char> <char style="w" strong="G01722">at</char> <char style="w" strong="G02993">Laodicea</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G02404">Hierapolis</char>.<verse eid="COL 4:13" /></para>
  <para style="p">
    <verse number="14" style="v" sid="COL 4:14" /><char style="w" strong="G03065">Luke</char>, <char style="w" strong="G03588">the</char> <char style="w" strong="G00027">beloved</char> <char style="w" strong="G02395">physician</char>, <char style="w" strong="G02532">and</char> <char style="w" strong="G01214">Demas</char> <char style="w" strong="G00782">send you greetings</char>.<verse eid="COL 4:14" /></para>
  <para style="s1">Signature and Final Instructions</para>
  <para style="r">(<ref loc="1CO 16:19-24">1 Corinthians 16:19–24</ref>; <ref loc="2TH 3:16-18">2 Thessalonians 3:16–18</ref>)</para>
  <para style="p">
    <verse number="15" style="v" sid="COL 4:15" /><char style="w" strong="G00782">Greet</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G00080">brothers</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G02993">Laodicea</char>, <char style="w" strong="G02532">as well as</char> <char style="w" strong="G03564">Nymphas</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G01577">church</char> <char style="w" strong="G02596">that meets at</char> <char style="w" strong="G00846">his</char> <char style="w" strong="G03624">house</char>.<note caller="+" style="f"><char style="fr" closed="false">4:15 </char><char style="ft" closed="false">NA, SBL, and WH </char><char style="fqa" closed="false">Nympha and the church that meets in her house</char></note><verse eid="COL 4:15" /></para>
  <para style="p">
    <verse number="16" style="v" sid="COL 4:16" /><char style="w" strong="G03752">After</char> <char style="w" strong="G03588">this</char> <char style="w" strong="G01992">letter</char> <char style="w" strong="G00314">has been read</char> <char style="w" strong="G03844">among</char> <char style="w" strong="G04771">you</char>, <char style="w" strong="G04160">make sure</char> <char style="w" strong="G02443">that</char> <char style="w" strong="G00314">it is also read</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G01577">church</char> <char style="w" strong="G02994">of the Laodiceans</char>, <char style="w" strong="G02532">and</char> <char style="w" strong="G02443">that</char> <char style="w" strong="G04771">you</char> <char style="w" strong="G02532">in turn</char> <char style="w" strong="G00314">read</char> <char style="w" strong="G03588">the letter</char> <char style="w" strong="G01537">from</char> <char style="w" strong="G02993">Laodicea</char>.<verse eid="COL 4:16" /></para>
  <para style="p">
    <verse number="17" style="v" sid="COL 4:17" /><char style="w" strong="G03004">Tell</char> <char style="w" strong="G00751">Archippus</char>: “<char style="w" strong="G00991">See to it</char> <char style="w" strong="G02443">that</char> <char style="w" strong="G04137">you complete</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G01248">ministry</char> <char style="w" strong="G03880">you have received</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G02962">the Lord</char>.”<verse eid="COL 4:17" /></para>
  <para style="p">
    <verse number="18" style="v" sid="COL 4:18" /><char style="w" strong="G03588">This</char> <char style="w" strong="G00783">greeting</char> <char style="w" strong="G03588">is in my</char> <char style="w" strong="G01699">own</char> <char style="w" strong="G05495">hand</char> — <char style="w" strong="G03972">Paul</char>.</para>
  <para style="p" vid="COL 4:18"><char style="w" strong="G03421">Remember</char> <char style="w" strong="G01473">my</char> <char style="w" strong="G01199">chains</char>.</para>
  <para style="p" vid="COL 4:18"><char style="w" strong="G05485">Grace be</char> <char style="w" strong="G03326">with</char> <char style="w" strong="G04771">you</char>. <char style="w" strong="G00281">Amen</char>.<note caller="+" style="f"><char style="fr" closed="false">4:18 </char><char style="ft" closed="false">CT does not include </char><char style="fqa" closed="false">Amen.</char></note><verse eid="COL 4:18" /></para>
  <chapter eid="COL 4" />
</usx>