  <para style="p">
    <verse number="28" style="v" sid="COL 1:28" /><char style="w" strong="G01473">We</char> <char style="w" strong="G02605">proclaim</char> <char style="w" strong="G03739">Him</char>, <char style="w" strong="G03560">admonishing</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G01321">teaching</char> <char style="w" strong="G03956">everyone</char> <char style="w" strong="G01722">with</char> <char style="w" strong="G03956">all</char> <char style="w" strong="G04678">wisdom</char>, <char style="w" strong="G02443">so that</char> <char style="w" strong="G03936">we may present</char> <char style="w" strong="G03956">everyone</char> <char style="w" strong="G05046">perfect</char><note caller="+" style="f"><char style="fr" closed="false">1:28 </char><char style="ft" closed="false">Or </char><char style="fqa" closed="false">fully mature</char></note> <char style="w" strong="G01722">in</char> <char style="w" strong="G05547">Christ</char> <char style="w" strong="G02424">Jesus</char>.<note caller="+" style="f"><char style="fr" closed="false">1:28 </char><char style="ft" closed="false">CT and F35 </char><char style="fqa" closed="false">in Christ</char></note> <verse eid="COL 1:28" /><verse number="29" style="v" sid="COL 1:29" /><char style="w" strong="G01519">To</char> <char style="w" strong="G03739">this end</char> <char style="w" strong="G02532">I also</char> <char style="w" strong="G02872">labor</char>, <char style="w" strong="G00075">striving</char> <char style="w" strong="G02596">with all</char> <char style="w" strong="G00846">His</char> <char style="w" strong="G01753">energy</char> <char style="w" strong="G01754">working</char> <char style="w" strong="G01411">powerfully</char> <char style="w" strong="G01722">within</char> <char style="w" strong="G01473">me</char>.<verse eid="COL 1:29" /></para>
  <chapter eid="COL 1" />
