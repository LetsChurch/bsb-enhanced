  <para style="p">
    <verse number="16" style="v" sid="COL 3:16" /><char style="w" strong="G03588">Let the</char> <char style="w" strong="G03056">word</char> <char style="w" strong="G05547">of Christ</char> <char style="w" strong="G04146">richly</char> <char style="w" strong="G01774">dwell</char> <char style="w" strong="G01722">within</char> <char style="w" strong="G04771">you</char> <char style="w" strong="G01321">as you teach</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G03560">admonish</char> <char style="w" strong="G01438">one another</char> <char style="w" strong="G01722">with</char> <char style="w" strong="G03956">all</char> <char style="w" strong="G04678">wisdom</char>, <char style="w" strong="G00103">and as you sing</char> <char style="w" strong="G05568">psalms</char>, <char style="w" strong="G05215">hymns</char>, <char style="w" strong="G02532">and</char> <char style="w" strong="G04152">spiritual</char> <char style="w" strong="G05603">songs</char> <char style="w" strong="G01722">with</char> <char style="w" strong="G05485">gratitude</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G04771">your</char> <char style="w" strong="G02588">hearts</char> <char style="w" strong="G03588">to the</char> <char style="w" strong="G02962">Lord</char>.<note caller="+" style="f"><char style="fr" closed="false">3:16 </char><char style="ft" closed="false">CT </char><char style="fqa" closed="false">to God</char></note> <verse eid="COL 3:16" /><verse number="17" style="v" sid="COL 3:17" /><char style="w" strong="G02532">And</char> <char style="w" strong="G03956">whatever</char> <char style="w" strong="G04160">you do</char>, <char style="w" strong="G01722">in</char> <char style="w" strong="G03056">word</char> <char style="w" strong="G02228">or</char> <char style="w" strong="G02041">deed</char>, <char style="w" strong="G03956">do it all</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G03686">the name</char> <char style="w"