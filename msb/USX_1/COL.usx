  <para style="p">
    <verse number="16" style="v" sid="COL 2:16" /><char style="w" strong="G03767">Therefore</char> <char style="w" strong="G03361">let no</char> <char style="w" strong="G05100">one</char> <char style="w" strong="G02919">judge</char> <char style="w" strong="G04771">you</char> <char style="w" strong="G01722">by</char> <char style="w" strong="G01035">what you eat</char> <char style="w" strong="G02228">or</char> <char style="w" strong="G04213">drink</char>, <char style="w" strong="G02228">or</char> <char style="w" strong="G01722">with</char> <char style="w" strong="G03313">regard to</char> <char style="w" strong="G01859">a feast</char>, <char style="w" strong="G03561">a New Moon</char>, <char style="w" strong="G02228">or</char> <char style="w" strong="G04521">a Sabbath</char>. <verse eid="COL 2:16" /><verse number="17" style="v" sid="COL 2:17" /><char style="w" strong="G03739">These</char> <char style="w" strong="G01510">are</char> <char style="w" strong="G04639">a shadow</char> <char style="w" strong="G03588">of the things</char> <char style="w" strong="G03195">to come</char>, <char style="w" strong="G01161">but</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G04983">body that casts it</char> <char style="w" strong="G03367">belongs to</char> <char style="w" strong="G05547">Christ</char>.<note caller="+" style="f"><char style="fr" closed="false">2:17 </char><char style="ft" closed="false">Literally </char><char style="fqa" closed="false">but the body is of the Christ</char></note> <verse eid="COL 2:17" /><verse number="18" style="v" sid="COL 2:18" /><char style="w" strong="G04771">Do not let anyone</char> <char style="w" strong="G02309">who delights</char> <char style="w" strong="G01722">in</char> <char style="w" strong="G05012">false humility</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G02356">the worship</char> <char style="w" strong="G00032">of angels</char> <char style="w" strong="G02603">disqualify you</char> <char style="w" strong="G01687">with speculation about</char> <char style="w" strong="G03739">what</char> <char style="w" strong="G03708">he has not seen</char>.<note caller="+" style="f"><char style="fr" closed="false">2:18 </char><char style="ft" closed="false">NA, SBL, WH, and TH </char><char style="fqa" closed="false">what he has seen</char></note> <char style="w" strong="G05448">Such a person is puffed up</char> <char style="w" strong="G01500">without basis</char> <char style="w" strong="G05259">by</char> <char style="w" strong="G00846">his</char> <char style="w" strong="G04561">unspiritual</char> <char style="w" strong="G03563">mind</char>. <verse eid="COL 2:18" /><verse number="19" style="v" sid="COL 2:19" /><char style="w" strong="G02902">He has lost connection</char> <char style="w" strong="G03588">to the</char> <char style="w" strong="G02776">head</char>, <char style="w" strong="G01537">from</char> <char style="w" strong="G03739">whom</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G03956">whole</char> <char style="w" strong="G04983">body</char>, <char style="w" strong="G02023">supported</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G04822">knit together</char> <char style="w" strong="G01223">by</char> <char style="w" strong="G03588">its</char> <char style="w" strong="G00860">joints</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G04886">ligaments</char>, <char style="w" strong="G00837">grows</char> <char style="w" strong="G03588">as</char> <char style="w" strong="G02316">God</char> <char style="w" strong="G00838">causes it to grow</char>.<verse eid="COL 2:19" /></para>
  <para style="p">
    <verse number="20" style="v" sid="COL 2:20" /><char style="w" strong="G01487">If</char><note caller="+" style="f"><char style="fr" closed="false">2:20 </char><char style="ft" closed="false">GOC, F35, and TR </char><char style="fqa" closed="false">If then</char></note> <char style="w" strong="G00599">you have died</char> <char style="w" strong="G04862">with</char> <char style="w" strong="G05547">Christ</char> <char style="w" strong="G00575">to</char> <char style="w" strong="G03588">the</char> <char style="w" strong="G04747">spiritual forces</char> <char style="w" strong="G03588">of the</char> <char style="w" strong="G02889">world</char>, <char style="w" strong="G05101">why</char>, <char style="w" strong="G05613">as though</char> <char style="w" strong="G02198">you still belonged</char> <char style="w" strong="G01722">to</char> <char style="w" strong="G02889">the world</char>, <char style="w" strong="G01379">do you submit to its regulations</char>: <verse eid="COL 2:20" /><verse number="21" style="v" sid="COL 2:21" />“<char style="w" strong="G03361">Do</char> <char style="w" strong="G00680">not handle</char>, <char style="w" strong="G03366">do</char> <char style="w" strong="G01089">not taste</char>, <char style="w" strong="G03366">do</char> <char style="w" strong="G02345">not touch</char>!”? <verse eid="COL 2:21" /><verse number="22" style="v" sid="COL 2:22" /><char style="w" strong="G03739">These</char> <char style="w" strong="G01510">will</char> <char style="w" strong="G03956">all</char> <char style="w" strong="G05356">perish</char> <char style="w" strong="G03588">with</char> <char style="w" strong="G00671">use</char>, <char style="w" strong="G02596">because they are based on</char> <char style="w" strong="G00444">human</char> <char style="w" strong="G01778">commands</char> <char style="w" strong="G02532">and</char> <char style="w" strong="G01319">teachings</char>. <verse eid="COL 2:22" /><verse number="23" style="v" sid="COL 2:23" /><char style="w" strong="G03748">Such restrictions</char> <char style="w" strong="G03303">indeed</char> <char style="w" strong="G02192">have</char> <char style="w" strong="G03056">an appearance</char> <char style="w" strong="G04678">of wisdom</char>, <char style="w" strong="G01722">with their</char> <char style="w" strong="G01479">self-prescribed worship</char>, <char style="w" strong="G05012">their false humility</char>, <char style="w" strong="G02532">and</char> <char style="w" strong="G00857">their harsh treatment</char> <char style="w" strong="G04983">of the body</char>; <char style="w" strong="G01510">but they are</char> <char style="w" strong="G01722">of</char> <char style="w" strong="G03756">no</char> <char style="w" strong="G05092">value</char> <char style="w" strong="G04314">against</char> <char style="w" strong="G04140">the indulgence</char> <char style="w" strong="G03588">of the</char> <char style="w" strong="G04561">flesh</char>.<verse eid="COL 2:23" /></para>
  <chapter eid="COL 2" />
