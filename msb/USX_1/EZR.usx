  <para style="p">
    <verse number="40" style="v" sid="EZR 2:40" /><char style="w" strong="H03881">The Levites</char>:</para>
  <para style="b" vid="EZR 2:40" />
  <para style="li1" vid="EZR 2:40"><char style="w" strong="H01121">the descendants</char> <char style="w" strong="H03442">of Jeshua</char> <char style="w" strong="H06934">and Kadmiel</char> (<char style="w" strong="H01121">through the line</char> <char style="w" strong="H01938">of Hodaviah</char><note caller="+" style="f"><char style="fr" closed="false">2:40 </char><char style="fqa" closed="false">Hodaviah </char><char style="ft" closed="false">is a variant of </char><char style="fqa" closed="false">Hodevah</char><char style="ft" closed="false">; see </char><char style="xt"><ref loc="NEH 7:43">Nehemiah 7:43</ref></char>.</note>), <char style="w" strong="H07657">74</char>.<verse eid="EZR 2:40" /></para>
  <para style="p">
    <verse number="41" style="v" sid="EZR 2:41" /><char style="w" strong="H07891">The singers</char>:</para>
