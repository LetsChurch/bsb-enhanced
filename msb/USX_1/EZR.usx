  <para style="li1" vid="EZR 2:41"><char style="w" strong="H01121">the descendants</char> <char style="w" strong="H00623">of Asaph</char>, <char style="w" strong="H03967">128</char>.<verse eid="EZR 2:41" /></para>
  <para style="p">
    <verse number="42" style="v" sid="EZR 2:42" /><char style="w" strong="H07778">The gatekeepers</char>:</para>
  <para style="b" vid="EZR 2:42" />
  <para style="li1" vid="EZR 2:42"><char style="w" strong="H01121">the descendants</char> <char style="w" strong="H07967">of Shallum</char>,</para>
  <para style="li1" vid="EZR 2:42"><char style="w" strong="H01121">the descendants</char> <char style="w" strong="H00333">of Ater</char>,</para>
  <para style="li1" vid="EZR 2:42"><char style="w" strong="H01121">the descendants</char> <char style="w" strong="H02929">of Talmon</char>,</para>
  <para style="li1" vid="EZR 2:42"><char style="w" strong="H01121">the descendants</char> <char style="w" strong="H06126">of Akkub</char>,</para>
  <para style="li1" vid="EZR 2:42"><char style="w" strong="H01121">the descendants</char> <char style="w" strong="H02410">of Hatita</char>,</para>
  <para style="li1" vid="EZR 2:42"><char style="w" strong="H01121">and the descendants</char> <char style="w" strong="H07630">of Shobai</char>,</para>
  <para style="li2" vid="EZR 2:42"><char style="w" strong="H03967">139</char> <char style="w" strong="H03605">in all</char>.<verse eid="EZR 2:42" /></para>
  <para style="p">
    <verse number="43" style="v" sid="EZR 2:43" /><char style="w" strong="H05411">The temple servants</char>:<note caller="+" style="f"><char style="fr" closed="false">2:43 </char><char style="ft" closed="false">Hebrew </char><char style="fqa" closed="false">The Nethinim</char><char style="ft" closed="false">; also in verses 58 and 70</char></note></para>
  <para style="b" vid="EZR 2:43" />
  <para style="li1" vid="EZR 2:43"><char style="w" strong="H01121">the descendants</char> <char style="w" strong="H06727">of Ziha</char>,</para>
