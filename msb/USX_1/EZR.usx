  <para style="li1">
    <verse number="46" style="v" sid="EZR 2:46" /><char style="w" strong="H01121">the descendants</char> <char style="w" strong="H02285">of Hagab</char>,</para>
  <para style="li1" vid="EZR 2:46"><char style="w" strong="H01121">the descendants</char> <char style="w" strong="H08073">of Shalmai</char>,<note caller="+" style="f"><char style="fr" closed="false">2:46 </char><char style="ft" closed="false">Alternate MT reading (see also </char><char style="xt"><ref loc="NEH 7:48">Nehemiah 7:48</ref></char>); the other alternate reads <char style="fqa" closed="false">Shamlai</char></note></para>
  <para style="li1" vid="EZR 2:46"><char style="w" strong="H01121">the descendants</char> <char style="w" strong="H02605">of Hanan</char>,<verse eid="EZR 2:46" /></para>
  <para style="li1">
