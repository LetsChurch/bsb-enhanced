  <para style="li1" vid="EZR 2:44"><char style="w" strong="H01121">the descendants</char> <char style="w" strong="H05517">of Siaha</char>,<note caller="+" style="f"><char style="fr" closed="false">2:44 </char><char style="fqa" closed="false">Siaha </char><char style="ft" closed="false">is a variant of </char><char style="fqa" closed="false">Sia</char><char style="ft" closed="false">; see </char><char style="xt"><ref loc="NEH 7:47">Nehemiah 7:47</ref></char>.</note></para>
  <para style="li1" vid="EZR 2:44"><char style="w" strong="H01121">the descendants</char> <char style="w" strong="H06303">of Padon</char>,<verse eid="EZR 2:44" /></para>
  <para style="li1">
    <verse number="45" style="v" sid="EZR 2:45" /><char style="w" strong="H01121">the descendants</char> <char style="w" strong="H03838">of Lebanah</char>,</para>
